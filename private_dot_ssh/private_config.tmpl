# Azure DevOps
# For Azure DevOps authentication, use Personal Access Tokens (PATs) with HTTPS
# Store your PAT in pass: pass add Logins/azure-devops/pat
# Then configure git credential helper:
#   git config --global credential.https://dev.azure.com.provider generic
# Or use environment variable: export AZURE_DEVOPS_PAT="$(pass show Logins/azure-devops/pat)"

# ─── Personal fleet (lowercase aliases, tailscale hostnames as canonical) ───
# Short aliases for quick `ssh p14`/`ssh t580` use. The TitleCase aliases above
# keep dev port-forwarding behavior for explicit session work.
# Tailscale hostnames resolve via MagicDNS when tailscaled is up.
Host p14
    HostName p14
    User {{ .chezmoi.username }}
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    IdentitiesOnly yes

Host t580
    HostName t580
    User {{ .chezmoi.username }}
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    IdentitiesOnly yes

Host zandvoort
    HostName zandvoort
    User {{ .chezmoi.username }}
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    IdentitiesOnly yes

Host sync-vm
    HostName sync-vm
    User {{ .chezmoi.username }}
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    IdentitiesOnly yes

{{ end -}}