{{ if not .remote -}}
# Homelab + work aliases — content kept out of the public dotfiles repo by
# living in pass (`pass show Homelab/ssh-config-local`), rendered into
# ~/.ssh/config.local by chezmoi (see private_dot_ssh/private_config.local.tmpl).
Include {{ .chezmoi.homeDir }}/.ssh/config.local
{{ if .isMacOS -}}
# colima ships an auto-managed ssh_config block for its lima VMs
Include {{ .chezmoi.homeDir }}/.config/colima/ssh_config
{{ end -}}

# Added by Augment for remote agent SSH connections
Include {{ .chezmoi.homeDir }}/.augment/ssh-config

# DevPod Start si-contracts.devpod
Host si-contracts.devpod
  ForwardAgent yes
  LogLevel error
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  HostKeyAlgorithms rsa-sha2-256,rsa-sha2-512,ssh-rsa
  ProxyCommand "{{ .chezmoi.homeDir }}/.local/bin/devpod" ssh --stdio --context default --user vscode si-contracts --workdir "/workspaces/contracts"
  User vscode
# DevPod End si-contracts.devpod
# DevPod Start si-platform.devpod
Host si-platform.devpod
  ForwardAgent yes
  LogLevel error
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  HostKeyAlgorithms rsa-sha2-256,rsa-sha2-512,ssh-rsa
  ProxyCommand "{{ .chezmoi.homeDir }}/.local/bin/devpod" ssh --stdio --context default --user vscode si-platform
  User vscode
# DevPod End si-platform.devpod
# DevPod Start sandbox.devpod
Host sandbox.devpod
  ForwardAgent yes
  LogLevel error
  StrictHostKeyChecking no
  UserKnownHostsFile /dev/null
  HostKeyAlgorithms rsa-sha2-256,rsa-sha2-512,ssh-rsa
  ProxyCommand "{{ .chezmoi.homeDir }}/.local/bin/devpod" ssh --stdio --context default --user vscode sandbox
  User vscode
# DevPod End sandbox.devpod

# GitHub — route through ssh.github.com:443 universally.
# Official GitHub guidance for restrictive networks; works on any network
# that allows outbound HTTPS (i.e. everywhere). Identical key auth, no
# downside vs port 22. Fixes intermittent "Connection timed out" on networks
# (e.g. p14's bluefin egress) that drop outbound port 22.
# https://docs.github.com/en/authentication/troubleshooting-ssh/using-ssh-over-the-https-port
Host github.com
    HostName ssh.github.com
    Port 443
    User git
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    IdentitiesOnly yes

# GitLab — keep on port 22 (no equivalent 443 endpoint documented)
Host gitlab.com
    HostName gitlab.com
    User git
    IdentityFile {{ .chezmoi.homeDir }}/.ssh/id_ed25519
    IdentitiesOnly yes

# Personal machines
# Local development port forwarding for web services
# Ports: 3000, 3001 (frontend dev), 13557 (API), 4983, 4321, 4848 (services)
Host Zandvoort
    ForwardAgent yes
    ExitOnForwardFailure no
    LocalForward 3000 127.0.0.1:3000
    LocalForward 3001 127.0.0.1:3001
    LocalForward 13557 127.0.0.1:13557
    LocalForward 4983 127.0.0.1:4983
    LocalForward 4321 127.0.0.1:4321
    LocalForward 4848 127.0.0.1:4848
    LogLevel=QUIET

Host T580
