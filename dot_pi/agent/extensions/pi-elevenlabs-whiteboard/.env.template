# Pi x ElevenLabs Whiteboard — environment template. Copy to .env (never commit .env).

# Hub HTTP server bind. Keep on loopback by default.
PIWB_HOST=127.0.0.1
PIWB_PORT=8848

# Public HTTPS base URL where ElevenLabs can reach this hub. Optional when using
# `bun run setup:public-voice --tunnel=tailscale`.
PIWB_PUBLIC_URL=
# Optional portable tunnel provider. Currently supported: tailscale.
PIWB_TUNNEL=

# Bearer token required by the public Custom LLM gateway (/v1/chat/completions).
# Generate a strong random value, e.g.: openssl rand -hex 32
PIWB_GATEWAY_TOKEN=

# ElevenLabs Conversational AI. The API key is server-side only and is NEVER
# exposed to the browser. The browser receives an ephemeral signed URL.
ELEVENLABS_API_KEY=
# Agent configured in the ElevenLabs dashboard to use this hub as its Custom LLM.
ELEVENLABS_AGENT_ID=
# "signed_url" (private agent, recommended) or "public" (public agent id only).
ELEVENLABS_AUTH_MODE=signed_url
# Default TTS voice. Override per-turn from the agent if desired.
ELEVENLABS_VOICE_ID=pq3wL6Xv3fuEM14W6ZCg

# Comma-separated host allowlist for the public gateway (tunnel hostnames).
# Empty = allow any Host (development only).
PIWB_GATEWAY_ALLOWED_HOSTS=
# Per-IP Custom LLM requests per minute. Set 0 to disable in local-only tests.
PIWB_GATEWAY_RATE_LIMIT_PER_MINUTE=30

# Optional persistence override. Defaults to ~/.pi/piwb in extension mode and
# ./.pi-data in standalone mode.
PIWB_DATA_DIR=

# Bridge implementation for the standalone hub: "pi" (real, in-extension) or
# "mock" (scripted echo, for tests without burning LLM tokens).
PIWB_BRIDGE=mock
