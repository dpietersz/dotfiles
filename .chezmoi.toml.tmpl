{{- $isMacOS := eq .chezmoi.os "darwin" -}}
{{- $isBluefin := and (stat "/etc/os-release") (contains "VARIANT_ID=bluefin" (output "cat" "/etc/os-release" | default "")) -}}
{{- $isBazzite := and (stat "/etc/os-release") (contains "VARIANT_ID=bazzite" (output "cat" "/etc/os-release" | default "")) -}}
{{- $isFedora := and (stat "/etc/os-release") (contains "ID=fedora" (output "cat" "/etc/os-release" | default "")) -}}
{{- $containerName := output "hostname" | trim -}}
{{/* Always-on Tailscale VMs (Proxmox-hosted, Debian) treated as "the fleet"
     even though they are SSH-accessed and not Bluefin. They get full chezmoi
     bootstrap (pass, keys, mise, cli tools) but skip GUI/Wayland/laptop
     configs via .chezmoiignore.tmpl. Extend this list when new server-class
     fleet members come online. */}}
{{- $serverHostnames := list "sync-vm" -}}
{{- $isServer := has $containerName $serverHostnames -}}
{{/* Per-host role assignments. isServer is the generic "headless always-on
     VM" flag; roles below opt individual hosts into specific workloads.
     Extend the dict when adding a new server with a new role, then add a
     role-gated `runsX` data field below. */}}
{{- $serverRoles := dict
  "sync-vm" (list "syncthing")
-}}
{{- $myRoles := (index $serverRoles $containerName) | default (list) -}}
{{- $runsSyncthing := has "syncthing" $myRoles -}}
{{- /* macOS is always a real personal device in this fleet (zandvoort).
       Bluefin + isServer ditto. None of them should be treated as
       "remote" just because chezmoi was invoked over SSH. The .remote
       flag exists for ephemeral containers (codespaces, devcontainers,
       docker.io), not for SSH'd-in fleet machines. */ -}}
{{- $remote := and (not $isBluefin) (not $isServer) (not $isMacOS) (or (env "CODESPACES" | not | not) (env "KUBERNETES_SERVICE_HOST" | not | not) (env "container" | not | not) (env "REMOTE_CONTAINERS" | not | not) (stat "/.dockerenv" | not | not)) -}}
{{- $hardwareModel := (and (stat "/sys/class/dmi/id/product_name") (output "cat" "/sys/class/dmi/id/product_name" | trim)) | default "" -}}
{{/* Detect fingerprint reader by probing USB for known vendor:product IDs of
     sensors supported by upstream libfprint. Gates on USB rather than DMI so
     it correctly identifies SKUs of the same chassis that ship without a
     reader, and stays useful across hardware changes. ~50ms cost per apply. */}}
{{- $usbList := "" -}}
{{- if and (not $isMacOS) (lookPath "lsusb") -}}
{{-   $usbList = output "bash" "-c" "lsusb 2>/dev/null || true" -}}
{{- end -}}
{{- $hasFingerprintReader := or
      (contains "06cb:00f9" $usbList)
      (contains "27c6:6594" $usbList)
      (contains "27c6:550a" $usbList)
      (contains "27c6:5395" $usbList)
      (contains "138a:0017" $usbList) -}}

{{/* Detect NVIDIA GPU via lspci. Drives which udx variant we expect.
     Cheap (~50ms) and works on Bluefin without root. */}}
{{- $hasNvidia := false -}}
{{- if and (not $isMacOS) (lookPath "lspci") -}}
{{-   $hasNvidia = output "bash" "-c" "lspci 2>/dev/null | grep -qi 'nvidia' && echo true || echo false" | trim | eq "true" -}}
{{- end -}}

{{/* Expected udx image for this machine (used by verify-image script). */}}
{{- $expectedImage := "ghcr.io/dpietersz/bluefin-udx" -}}
{{- if $hasNvidia -}}
{{-   $expectedImage = "ghcr.io/dpietersz/bluefin-udx-nvidia" -}}
{{- end -}}

{{/* Detect whether this machine is actually booted into a bluefin-udx image.
     Bluefin pre-bootc-CLI uses `rpm-ostree status --json` to expose the booted
     container origin. The container-image-reference field looks like
     "ostree-unverified-registry:ghcr.io/dpietersz/bluefin-udx:stable" — we
     match on the udx prefix to allow either variant. */}}
{{- $bootedImage := "" -}}
{{- if and (not $isMacOS) (lookPath "rpm-ostree") (lookPath "jq") -}}
{{-   $bootedImage = output "bash" "-c" "rpm-ostree status --json 2>/dev/null | jq -r '.deployments[] | select(.booted==true) | .\"container-image-reference\" // \"\"' 2>/dev/null || echo ''" | trim -}}
{{- end -}}
{{- $isBluefinUdx := and $isBluefin (contains "ghcr.io/dpietersz/bluefin-udx" $bootedImage) -}}

{{/* Probe a second battery (T580 UltraBay slice). thinkpad_acpi exposes each
     battery's thresholds via charge_control_start_threshold and
     charge_control_end_threshold under each BAT* power_supply entry.
     Single-battery machines (P14s G5 AMD) render hasBat1=false. */}}
{{- $hasBat1 := false -}}
{{- if stat "/sys/class/power_supply/BAT1" -}}
{{-   $hasBat1 = true -}}
{{- end -}}

sourceDir = {{ .chezmoi.sourceDir | quote }}

[data]
  remote = {{ if $remote }}true{{ else }}false{{ end }}
  isMacOS = {{ if $isMacOS }}true{{ else }}false{{ end }}
  isBluefin = {{ if $isBluefin }}true{{ else }}false{{ end }}
  isBazzite = {{ if $isBazzite }}true{{ else }}false{{ end }}
  isFedora = {{ if $isFedora }}true{{ else }}false{{ end }}
  gpgKeyId = "207F38BA91AB8330DBF08766B4320995C8E1D17D"
  hardwareModel = {{ $hardwareModel | quote }}
  hasFingerprintReader = {{ if $hasFingerprintReader }}true{{ else }}false{{ end }}
  hasNvidia = {{ if $hasNvidia }}true{{ else }}false{{ end }}
  expectedImage = {{ $expectedImage | quote }}
  bootedImage = {{ $bootedImage | quote }}
  isBluefinUdx = {{ if $isBluefinUdx }}true{{ else }}false{{ end }}
  isServer = {{ if $isServer }}true{{ else }}false{{ end }}
  runsSyncthing = {{ if $runsSyncthing }}true{{ else }}false{{ end }}
  hasBat1 = {{ if $hasBat1 }}true{{ else }}false{{ end }}
  # Battery charge mode: "eco" (75/80) or "full" (96/100). Toggle via
  # Mod+Alt+B (kitty popup runs `battery-toggle`). Default "eco" preserves
  # cell life on plugged-in workloads. See:
  # .chezmoiscripts/run_onchange_after_21-apply-battery-thresholds.sh.tmpl
  batteryMode = "eco"

{{- if not $remote }}
[git]
  autoCommit = true
  autoPush = true
{{- end }}
