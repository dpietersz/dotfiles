{{- if .isMacOS }}
# Exclude Wayland/Linux-specific configs on macOS
.config/niri/
.config/noctalia/
.config/systemd/
.config/distrobox/
.config/hypr/
.local/bin/scripts/niri-idle-daemon.sh
# Vibe Typer is Linux-only (AppImage); the parent dir doesn't exist on macOS
.config/vibe-typer/
.config/autostart/
{{- end }}

{{- if or .isMacOS (not (and (hasKey . "hasFingerprintReader") .hasFingerprintReader)) }}
# Fingerprint lockscreen stack — only deploy on Linux machines with a supported sensor.
# Other Linux machines keep noctalia v5's built-in lockscreen. macOS skips entirely.
.config/hypr/
.local/bin/scripts/niri-idle-daemon.sh
{{- end }}

