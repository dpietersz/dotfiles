#!/bin/bash
# niri-mirror-toggle — toggle the external monitor between MIRROR and EXTEND.
#
# niri has no native output mirroring, so MIRROR is implemented with wl-mirror:
# a fullscreen mirror window of the internal panel placed on the external output.
# EXTEND is just niri's normal multi-output layout (kill the mirror window).
#
# Bound to Ctrl+Alt+M in dot_config/niri/config.kdl.tmpl.
set -euo pipefail

APPID="at.yrlf.wl_mirror"
# Connector-name prefixes that identify a built-in laptop panel.
INTERNAL_RE='^(eDP|LVDS|DSI)'

notify() { command -v notify-send >/dev/null 2>&1 && notify-send -a "Display" "$@" || true; }

# Window id of a running wl-mirror, via niri (namespace-agnostic). Empty if none.
mirror_window_id() {
  niri msg -j windows 2>/dev/null | jq -r --arg a "$APPID" 'map(select(.app_id==$a)) | .[0].id // empty'
}

# wl-mirror lives host-native once baked into bluefin-udx; until then it runs in
# the Arch udx-toolbox (shares the Wayland socket). Prefer the host binary.
mirror_cmd() {
  if command -v wl-mirror >/dev/null 2>&1; then
    echo "wl-mirror"
  elif command -v distrobox >/dev/null 2>&1 && distrobox list 2>/dev/null | grep -q udx-toolbox; then
    echo "distrobox enter udx-toolbox -- wl-mirror"
  else
    echo ""
  fi
}

# --- toggle OFF: a mirror is running -> back to extended desktop -------------
wid="$(mirror_window_id)"
if [[ -n "$wid" ]]; then
  niri msg action close-window --id "$wid" 2>/dev/null || true
  pkill -x wl-mirror 2>/dev/null || true   # backstop for any orphaned chain
  notify "Extended desktop" "Mirror off"
  exit 0
fi

# --- toggle ON: no mirror -> mirror internal panel onto external output ------
internal="$(niri msg -j outputs | jq -r 'keys[]' | grep -iE "$INTERNAL_RE" | head -1)"
external="$(niri msg -j outputs | jq -r 'keys[]' | grep -ivE "$INTERNAL_RE" | head -1)"

if [[ -z "$external" ]]; then
  notify "No external monitor" "Nothing to mirror to"
  exit 0
fi
if [[ -z "$internal" ]]; then
  notify "Mirror failed" "Could not identify the internal panel"
  exit 1
fi

cmd="$(mirror_cmd)"
if [[ -z "$cmd" ]]; then
  notify "Mirror failed" "wl-mirror not found (host or udx-toolbox)"
  exit 1
fi

# Detach fully so it survives this script (and niri's spawn) exiting.
# shellcheck disable=SC2086
setsid -f $cmd --fullscreen-output "$external" "$internal" </dev/null >/dev/null 2>&1
notify "Mirroring" "$internal → $external"
