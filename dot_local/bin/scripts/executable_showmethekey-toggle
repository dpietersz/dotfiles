#!/bin/bash
# Toggle the showmethekey-gtk floating-overlay window on/off.
# Bound to Mod+Shift+I in niri (for OBS demo recordings).
#
# v1.17.0 (pesader/showmethekey COPR) only exposes -a/--active to auto-spawn
# the floating overlay. "Always on top" and "click-through" are not CLI flags
# in this version — they're per-session GUI toggles inside the overlay's
# settings panel, and 'open-floating' niri rules handle the tiling concern.
#
# The proc name 'showmethekey-gtk' is 17 chars > the 15-char kernel comm
# limit, so pkill -x / pgrep -x can't match it. We use -f against the full
# command line instead.

set -euo pipefail

if ! command -v showmethekey-gtk >/dev/null; then
  echo "showmethekey-toggle: showmethekey-gtk not installed — rebase to latest bluefin-udx" >&2
  exit 0
fi

if pgrep -f '^/usr/bin/showmethekey-gtk\b' >/dev/null 2>&1; then
  pkill -f '^/usr/bin/showmethekey-gtk\b'
  # Known v1.17.0 leak: the polkit-elevated /usr/bin/showmethekey-cli helper
  # keeps running as root after the GTK frontend dies, and user-space pkill
  # returns EPERM on it. SIGINT to the frontend doesn't trigger orderly
  # helper shutdown either. Each toggle-on leaves one stale helper until
  # next reboot — or until you manually run:
  #     sudo pkill -f '^/usr/bin/showmethekey-cli\b'
  # Negligible per-process footprint; revisit if pesader/showmethekey COPR
  # picks up a release that fixes the orderly-shutdown path.
else
  exec /usr/bin/showmethekey-gtk -a
fi
