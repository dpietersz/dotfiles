// Niri compositor — see https://yalter.github.io/niri/Configuration:-Introduction
//
// This file is rendered by chezmoi. Per-machine monitor positioning lives in
// `monitor.kdl` (auto-generated by nwg-displays, NOT managed by chezmoi).
// Theme colors live in `theme.kdl` (rendered by `theme-switch`, see
// dot_config/themes/). Both are pulled in at the bottom of this file.

include "monitor.kdl"
include "theme.kdl"

// ----------------------------------------------------------------------------
// Launch at startup
// ----------------------------------------------------------------------------

// Noctalia v5 desktop shell (bar + launcher + notifications + OSD + lock).
spawn-at-startup "noctalia"

// Polkit auth agent. niri ships none; pkexec-using GUI apps (vibe-typer) fail
// without one. mate-polkit chosen because noctalia's built-in agent didn't
// play well with vibe-typer's setup flow.
spawn-at-startup "/usr/libexec/polkit-mate-authentication-agent-1"

// Vibe Typer voice dictation. --password-store flips Electron's keyring
// backend without setting XDG_CURRENT_DESKTOP=GNOME (which would break the
// noctalia SNI tray icon path). 3s sleep waits for gnome-keyring's secret
// service so vibe-typer's saved token can be decrypted.
spawn-at-startup "sh" "-c" "sleep 3 && exec \"$HOME/Applications/VibeTyper.AppImage\" --password-store=gnome-libsecret --autostart"

// Idle/lock stack: swayidle drives screen-off → hyprlock → suspend on every niri
// machine. hyprlock authenticates by fingerprint where a sensor exists and by
// password otherwise. noctalia's own idle handlers are disabled (see
// dot_config/noctalia/config.toml.tmpl).
spawn-at-startup "niri-idle-daemon.sh"

// Auto power profile: battery → power-saver, AC → balanced (on transitions only;
// manual noctalia/keybind choices are respected in between). Sets the same
// net.hadess.PowerProfiles the noctalia widget reads.
spawn-at-startup "power-profile-auto.sh"

// Workspace-follows-external-monitor hotplug daemon. Subscribes to niri's
// JSON event stream; on OutputAdded moves all dynamic workspaces to the new
// monitor, on OutputRemoved lets niri's default fallback take over.
spawn-at-startup "niri-monitor-follow"

// niri 26.04 quirks driving these declarations:
//   1. move-window-to-workspace will NOT auto-create a named workspace; it
//      must be declared up front. So we declare "scratchpad".
//   2. Static (declared) workspaces always sort BEFORE dynamic ones, in
//      declaration order. Declaring "scratchpad" alone would shove it to
//      idx 1 — stealing Mod+1 from the user's normal workspace. So we
//      pre-declare workspaces 1-9 with numeric names, then "scratchpad" at
//      the end (idx 10). Mod+1..9 binds reference idx 1..9 as before.
//   3. noctalia's `hide_when_empty = true` hides the scratchpad pill when
//      its window is currently revealed (i.e. when the scratchpad workspace
//      is empty), so it's only visible in the bar when the scratchpad is
//      hidden — which is also when the user might want to remember it's
//      stashed there.
workspace "1"
workspace "2"
workspace "3"
workspace "4"
workspace "5"
workspace "6"
workspace "7"
workspace "8"
workspace "9"
workspace "scratchpad"

// ----------------------------------------------------------------------------
// Input
// ----------------------------------------------------------------------------

input {
    keyboard {
        repeat-delay 200
        repeat-rate 40
    }
    touchpad {
        tap
        accel-profile "flat"
    }
    mouse {
        accel-profile "flat"
        accel-speed 0.65
        scroll-factor 1.50
    }
}

// ----------------------------------------------------------------------------
// Behavior and aesthetics
// ----------------------------------------------------------------------------

prefer-no-csd
screenshot-path null

hotkey-overlay {
    skip-at-startup
}

gestures {
    hot-corners {
        off
    }
}

environment {
    XDG_CURRENT_DESKTOP "niri"
    MOZ_ENABLE_WAYLAND "1"
    QT_QPA_PLATFORM "wayland"
    ELECTRON_OZONE_PLATFORM_HINT "wayland"
    QT_QPA_PLATFORMTHEME "gtk3"
    QT_QPA_PLATFORMTHEME_QT6 "gtk3"
    TERMINAL "kitty"
    XCURSOR_THEME "Bibata-Modern-Ice"
    XCURSOR_SIZE "24"
}

layout {
    gaps 8
    center-focused-column "never"
    always-center-single-column

    preset-column-widths {
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }
    default-column-width { proportion 0.5; }

    focus-ring {
        width 1
    }
    border {
        off
    }
    shadow {
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    struts {}
}

debug {
    // Let noctalia trigger window activation reliably.
    honor-xdg-activation-with-invalid-serial
}

// ----------------------------------------------------------------------------
// Window rules
// ----------------------------------------------------------------------------

// Slight rounded corners with clip-to-geometry, applied globally.
window-rule {
    geometry-corner-radius 2
    clip-to-geometry true
    draw-border-with-background false
}

// Persistent scratchpad terminal (toggle via scratchpad-toggle script).
// Floating, fixed 1025px width (proportion 0.33 was too narrow), 1/2 height.
// niri centers floating windows by default (no position set), so it stays
// centered. Kept around between toggles by the script so the shell session
// keeps running.
window-rule {
    match app-id="scratchpad-term"
    open-floating true
    default-column-width { fixed 1025; }
    default-window-height { proportion 0.5; }
}

// Floating fzf-driven popups (kitty --class …). Same pattern as Nick's
// floating ghostty rules.
window-rule {
    match app-id="cheatsheet"
    open-floating true
    default-column-width { fixed 900; }
    default-window-height { fixed 700; }
}

window-rule {
    match app-id="shell-cheatsheet"
    open-floating true
    default-column-width { fixed 1200; }
    default-window-height { fixed 700; }
}

window-rule {
    match app-id="fpass-popup"
    open-floating true
    default-column-width { fixed 700; }
    default-window-height { fixed 500; }
}

window-rule {
    match app-id="fssh-popup"
    open-floating true
    default-column-width { fixed 700; }
    default-window-height { fixed 500; }
}

window-rule {
    match app-id="fabric-popup"
    open-floating true
    default-column-width { fixed 1200; }
    default-window-height { fixed 800; }
}

window-rule {
    match app-id="kondo-popup"
    open-floating true
    default-column-width { fixed 1100; }
    default-window-height { fixed 750; }
}

window-rule {
    match app-id="pandoc-popup"
    open-floating true
    default-column-width { fixed 1100; }
    default-window-height { fixed 750; }
}

window-rule {
    match app-id="workspace-template-popup"
    open-floating true
    default-column-width { fixed 900; }
    default-window-height { fixed 500; }
}

window-rule {
    match app-id="battery-popup"
    open-floating true
    default-column-width { fixed 720; }
    default-window-height { fixed 420; }
}

// showmethekey settings/main window — v1.17.0 can't be configured to
// start with the settings panel hidden, and closing the settings window
// terminates the whole app. Stash it on the scratchpad workspace so it
// stays out of the way; toggle the whole app off via Mod+Shift+I, which
// pkills the gtk process (both windows die together). Off-screen
// positioning was tried first but niri clamps coords to monitor bounds.
window-rule {
    match app-id="one.alynx.showmethekey"
    open-floating true
    open-focused false
    open-on-workspace "scratchpad"
    default-column-width { fixed 800; }
    default-window-height { fixed 600; }
}

// showmethekey floating overlay (the keystroke display) — bottom-center
// of the panel, 50px above the bottom edge. Standard streamer/YouTuber
// position (EposVox-style). Logical desktop on the P14s is 2048x1280
// after 1.25x scale; overlay is 1500x200 so x = (2048-1500)/2 = 274.
// For OBS recordings, add this window as its own Window Capture source
// in OBS and re-position it on the canvas where you want — the desktop
// position is only for your own visual feedback while recording.
window-rule {
    match app-id="showmethekey-gtk"
    open-floating true
    default-column-width { fixed 1500; }
    default-window-height { fixed 200; }
    default-floating-position x=274 y=50 relative-to="bottom-left"
}

window-rule {
    match app-id="window-switcher"
    open-floating true
    default-column-width { fixed 900; }
    default-window-height { fixed 600; }
}

window-rule {
    match app-id="devtool-popup"
    open-floating true
    default-column-width { fixed 900; }
    default-window-height { fixed 600; }
}

window-rule {
    match app-id="theme-popup"
    open-floating true
    default-column-width { fixed 600; }
    default-window-height { fixed 400; }
}

window-rule {
    match app-id="zellij-picker"
    open-floating true
    default-column-width { fixed 480; }
    default-window-height { fixed 180; }
    default-floating-position x=784 y=550 relative-to="top-left"
}

// Satty (screenshot annotator) floats so it never tiles into the active layout.
window-rule {
    match app-id=r#"^com\.gabm\.satty$"#
    open-floating true
    min-width 730
    min-height 300
}

// LocalSend (StartupWMClass empty — verify with `niri msg windows`).
window-rule {
    match app-id="(?i)^localsend$"
    open-floating true
}

// Vibe Typer recording indicator — small floating timer/waveform pill that
// pops up while transcribing. Shares app-id "vibe-typer" with the main window,
// so scope on title. The newer version registers it as a real toplevel, so it
// grabbed the focus-ring (the orange border). Kill the ring + border on it.
window-rule {
    match app-id="vibe-typer" title="Recording Indicator"
    focus-ring {
        off
    }
    border {
        off
    }
}

// ----------------------------------------------------------------------------
// Key binds
// ----------------------------------------------------------------------------

binds {
    // === Session ===
    Ctrl+Alt+Delete hotkey-overlay-title=null { quit; }
    Mod+Escape allow-inhibiting=false hotkey-overlay-title="Toggle keyboard-shortcut inhibitor" { toggle-keyboard-shortcuts-inhibit; }
    Ctrl+Alt+L hotkey-overlay-title="Lock Screen (hyprlock)" { spawn "niri-lock.sh"; }
    Mod+Backspace hotkey-overlay-title="Session menu" { spawn "noctalia" "msg" "panel-toggle" "session"; }

    // === Overview / hotkey overlay ===
    Mod+O hotkey-overlay-title="Toggle overview" { toggle-overview; }
    Mod+Shift+O hotkey-overlay-title="Toggle focused window between OBS 1920x1080 and previous size" { spawn "niri-obs-toggle"; }
    Mod+Shift+I hotkey-overlay-title="Toggle showmethekey keystroke overlay (recording mode: -a, auto-spawn floating overlay)" { spawn "showmethekey-toggle"; }
    Mod+Shift+Slash hotkey-overlay-title="Show hotkey overlay" { show-hotkey-overlay; }

    // === fzf popups (search & pickers) ===
    Mod+Slash hotkey-overlay-title="fzf: search keybindings" { spawn "kitty" "--class" "cheatsheet" "--" "niri-cheatsheet"; }
    Mod+A     hotkey-overlay-title="fzf: search bash aliases & functions" { spawn "kitty" "--class" "shell-cheatsheet" "--" "niri-shell-cheatsheet"; }
    Mod+P     hotkey-overlay-title="fzf: pick pass entry → copy password" { spawn "kitty" "--class" "fpass-popup" "--" "niri-fpass-popup"; }
    Mod+G     hotkey-overlay-title="fzf: pick SSH host → open kitty" { spawn "kitty" "--class" "fssh-popup" "--" "niri-fssh-popup"; }
    Mod+F     hotkey-overlay-title="fzf+fabric: pick pattern(s) → run → copy" { spawn "kitty" "--class" "fabric-popup" "--" "niri-fabric-popup"; }
    Mod+C     hotkey-overlay-title="fzf+kondo: pick scan root → clean build dirs" { spawn "kitty" "--class" "kondo-popup" "--" "niri-kondo-popup"; }
    Mod+M     hotkey-overlay-title="fzf+pandoc: pick note → convert to pdf/docx/html" { spawn "kitty" "--class" "pandoc-popup" "--" "niri-pandoc-popup"; }
    Mod+T     hotkey-overlay-title="fzf: switch focused window" { spawn "kitty" "--class" "window-switcher" "--" "niri-window-switch"; }
    Mod+E     hotkey-overlay-title="fzf: workspace template (Environment) — open/close" { spawn "kitty" "--class" "workspace-template-popup" "--" "niri-workspace-template-popup"; }

    // === Launchers ===
    Mod+Return       hotkey-overlay-title="Kitty: session picker (zoxide dirs + ssh)" { spawn "kitty-session" "--pick"; }
    Mod+Shift+Return hotkey-overlay-title="Kitty: list open sessions (switch / kill)" { spawn "kitty-session" "--list"; }
    Mod+Tab          hotkey-overlay-title="Kitty: alternate session (toggle last two)" { spawn "kitty-session" "--alt"; }
    Ctrl+Alt+S       hotkey-overlay-title="Toggle scratchpad terminal" { spawn "scratchpad-toggle"; }
    Ctrl+Alt+M       hotkey-overlay-title="Toggle external monitor: mirror ↔ extend" { spawn "niri-mirror-toggle"; }
    Mod+V            hotkey-overlay-title="Launch kitty terminal" { spawn "kitty"; }
    Mod+Space        hotkey-overlay-title="Launcher (Noctalia)" { spawn "noctalia" "msg" "panel-toggle" "launcher"; }
    Mod+Shift+V      hotkey-overlay-title="Clipboard history" { spawn "noctalia" "msg" "panel-toggle" "clipboard"; }
    Mod+Ctrl+Space   hotkey-overlay-title="Toggle Noctalia bar" { spawn "noctalia" "msg" "bar-toggle"; }
    Mod+X            hotkey-overlay-title="Devtool (calc + conversions)" { spawn "kitty" "--class" "devtool-popup" "--" "niri-devtool-popup"; }

    // === Themes ===
    Mod+Ctrl+BackSlash       hotkey-overlay-title="Cycle theme" { spawn "theme-switch" "--cycle"; }
    Mod+Ctrl+Shift+BackSlash hotkey-overlay-title="Pick theme" { spawn "kitty" "--class" "theme-popup" "--" "niri-theme-popup"; }

    // === Volume / mic / brightness / media (noctalia OSD) ===
    XF86AudioRaiseVolume  allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "volume-up"; }
    XF86AudioLowerVolume  allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "volume-down"; }
    XF86AudioMute         allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "volume-mute"; }
    XF86AudioMicMute      allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "mic-mute"; }
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "brightness-down"; }
    XF86MonBrightnessUp   allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "brightness-up"; }
    XF86AudioNext         allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "next"; }
    XF86AudioPause        allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "toggle"; }
    XF86AudioPlay         allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "toggle"; }
    XF86AudioPrev         allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "previous"; }
    XF86Bluetooth         hotkey-overlay-title=null { spawn "bash" "-c" "bluetoothctl show | grep -q 'Powered: yes' && bluetoothctl power off || bluetoothctl power on"; }
    XF86WLAN              hotkey-overlay-title=null { spawn "nmcli" "radio" "wifi"; }

    // === System helpers ===
    Mod+Shift+B hotkey-overlay-title="Fix BT audio (restart wireplumber + reconnect)" { spawn "fix-bt-audio"; }
    Mod+Alt+B   hotkey-overlay-title="Toggle battery charge mode (eco ↔ full)" { spawn "battery-toggle-popup"; }

    // === Mouse live-tune ===
    Mod+Ctrl+Equal  hotkey-overlay-title="Mouse: accel-speed +0.10"   { spawn "niri-mouse-tune" "accel" "up"; }
    Mod+Ctrl+Minus  hotkey-overlay-title="Mouse: accel-speed 0.65"   { spawn "niri-mouse-tune" "accel" "down"; }
    Mod+Ctrl+Period hotkey-overlay-title="Mouse: scroll-factor +0.25" { spawn "niri-mouse-tune" "scroll" "up"; }
    Mod+Ctrl+Comma  hotkey-overlay-title="Mouse: scroll-factor 1.50" { spawn "niri-mouse-tune" "scroll" "down"; }

    // === Window / column ===
    Mod+Q repeat=false hotkey-overlay-title=null { close-window; }
    Mod+Alt+F          hotkey-overlay-title="Maximize column"                       { maximize-column; }
    Mod+Shift+F        hotkey-overlay-title="Full screen window"                    { fullscreen-window; }
    Mod+Ctrl+F         hotkey-overlay-title="Expand column to available width"     { expand-column-to-available-width; }
    Mod+W              hotkey-overlay-title="Toggle floating window"               { toggle-window-floating; }
    Mod+Ctrl+W         hotkey-overlay-title="Switch focus floating ↔ tiling"      { switch-focus-between-floating-and-tiling; }
    Mod+Shift+T        hotkey-overlay-title="Toggle tabbed column (group/tabs)"   { toggle-column-tabbed-display; }
    Mod+I              hotkey-overlay-title="Focus previously focused window"      { focus-window-previous; }
    Mod+Ctrl+C         hotkey-overlay-title="Center column"                        { center-column; }

    // Consume / expel
    Mod+BracketLeft  hotkey-overlay-title="Move window in/out of column to the left"  { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Move window in/out of column to the right" { consume-or-expel-window-right; }
    Mod+Comma        hotkey-overlay-title="Consume right window into column"          { consume-window-into-column; }
    Mod+Period       hotkey-overlay-title="Expel bottom window from column"           { expel-window-from-column; }

    // === Focus navigation ===
    // J/K mirror Down/Up — within a tabbed column they cycle tabs; in a
    // vertical column they cycle stacked windows.
    Mod+Down  hotkey-overlay-title="Focus window down"   { focus-window-down; }
    Mod+Up    hotkey-overlay-title="Focus window up"     { focus-window-up; }
    // J / K wrap around in tabbed columns: down at the bottom jumps to the
    // top tab, up at the top jumps to the bottom tab. Mod+Down / Mod+Up
    // intentionally stay non-wrapping so the J/K vs arrow distinction is a
    // user-facing choice.
    Mod+J     hotkey-overlay-title=null                  { focus-window-down-or-top; }
    Mod+K     hotkey-overlay-title=null                  { focus-window-up-or-bottom; }
    Mod+H     hotkey-overlay-title=null                  { focus-column-left; }
    Mod+L     hotkey-overlay-title=null                  { focus-column-right; }
    Mod+Home  hotkey-overlay-title="Focus first column"  { focus-column-first; }
    Mod+End   hotkey-overlay-title="Focus last column"   { focus-column-last; }

    // === Window movement ===
    Mod+Shift+Down  hotkey-overlay-title="Move window down" { move-window-down; }
    Mod+Shift+Up    hotkey-overlay-title="Move window up"   { move-window-up; }
    Mod+Shift+J     hotkey-overlay-title=null               { move-window-down; }
    Mod+Shift+K     hotkey-overlay-title=null               { move-window-up; }
    Mod+Shift+H     hotkey-overlay-title=null               { move-column-left; }
    Mod+Shift+L     hotkey-overlay-title=null               { move-column-right; }

    // === Sizing ===
    Mod+R           hotkey-overlay-title="Cycle preset column widths" { switch-preset-column-width; }
    Mod+Shift+R     hotkey-overlay-title="Cycle preset window heights" { switch-preset-window-height; }
    Mod+Ctrl+R      hotkey-overlay-title="Reset window height" { reset-window-height; }
    Mod+Minus       hotkey-overlay-title="Decrease column width"  { set-column-width "-10%"; }
    Mod+Equal       hotkey-overlay-title="Increase column width"  { set-column-width "+10%"; }
    Mod+Shift+Minus hotkey-overlay-title="Decrease window height" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Increase window height" { set-window-height "+10%"; }

    // === Monitor navigation ===
    Mod+Ctrl+H hotkey-overlay-title="Focus left monitor"  { focus-monitor-left; }
    Mod+Ctrl+J hotkey-overlay-title="Focus lower monitor" { focus-monitor-down; }
    Mod+Ctrl+K hotkey-overlay-title="Focus upper monitor" { focus-monitor-up; }
    Mod+Ctrl+L hotkey-overlay-title="Focus right monitor" { focus-monitor-right; }

    Mod+Shift+Ctrl+H hotkey-overlay-title="Move column to left monitor"  { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J hotkey-overlay-title="Move column to lower monitor" { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K hotkey-overlay-title="Move column to upper monitor" { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L hotkey-overlay-title="Move column to right monitor" { move-column-to-monitor-right; }

    // === Workspaces ===
    // D = Down (next workspace), U = Up (previous). Frees J/K for windows.
    Mod+D             hotkey-overlay-title="Focus next workspace"     { focus-workspace-down; }
    Mod+U             hotkey-overlay-title="Focus previous workspace" { focus-workspace-up; }
    Mod+Ctrl+D        hotkey-overlay-title="Move column to next workspace"     { move-column-to-workspace-down; }
    Mod+Ctrl+U        hotkey-overlay-title="Move column to previous workspace" { move-column-to-workspace-up; }
    Mod+Ctrl+Alt+Down hotkey-overlay-title=null { move-column-to-workspace-down; }
    Mod+Ctrl+Alt+Up   hotkey-overlay-title=null { move-column-to-workspace-up; }
    Mod+Shift+D       hotkey-overlay-title="Move workspace down" { move-workspace-down; }
    Mod+Shift+U       hotkey-overlay-title="Move workspace up"   { move-workspace-up; }

    // Scroll-wheel workspace navigation (cooldown so a quick flick doesn't
    // teleport across many workspaces).
    Mod+Shift+WheelScrollDown      cooldown-ms=150 hotkey-overlay-title="Focus next workspace" { focus-workspace-down; }
    Mod+Shift+WheelScrollUp        cooldown-ms=150 hotkey-overlay-title="Focus previous workspace" { focus-workspace-up; }
    Mod+Ctrl+Shift+WheelScrollDown cooldown-ms=150 hotkey-overlay-title="Move column to next workspace" { move-column-to-workspace-down; }
    Mod+Ctrl+Shift+WheelScrollUp   cooldown-ms=150 hotkey-overlay-title="Move column to previous workspace" { move-column-to-workspace-up; }

    // Numbered workspaces — 1-9 declared in niri ("scratchpad" at idx 10).
    // Description on first row only (Nick pattern).
    Mod+1 hotkey-overlay-title="Focus workspace (1-9)" { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }

    Mod+Shift+1 hotkey-overlay-title="Move column to workspace (1-9)" { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    // === Screenshots ===
    Mod+S            hotkey-overlay-title="Screenshot (region)"           { spawn "dot-screenshot" "region"; }
    Mod+Shift+S      hotkey-overlay-title="Screenshot (window)"           { spawn "dot-screenshot" "window"; }
    Mod+Ctrl+S       hotkey-overlay-title="Screenshot (monitor: focused)" { spawn "dot-screenshot" "monitor-focused"; }
    Mod+Ctrl+Shift+S hotkey-overlay-title="Screenshot (monitor: all)"     { spawn "dot-screenshot" "monitor-all"; }

    // === Workspace tooling ===
    // Toggle the active workspace between laptop (eDP-*) and the external
    // monitor (any HDMI/DP, not just the LG). Script auto-detects the
    // external by ruling out eDP-* and no-ops cleanly when nothing's plugged in.
    Mod+Shift+M hotkey-overlay-title="Toggle workspace to other monitor" { spawn "toggle-workspace-monitor"; }
}
