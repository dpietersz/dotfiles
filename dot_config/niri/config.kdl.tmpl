// Settings that influence how windows are positioned and sized.
// Find more information on the wiki:
// https://github.com/YaLTeR/niri/wiki/Configuration:-Layout
layout {
    // Set gaps around windows in logical pixels.
    gaps 5
    // When to center a column when changing focus, options are:
    // - "never", default behavior, focusing an off-screen column will keep at the left
    //   or right edge of the screen.
    // - "always", the focused column will always be centered.
    // - "on-overflow", focusing a column will center it if it doesn't fit
    //   together with the previously focused column.
    center-focused-column "never"

    // Center a single column on a workspace
    always-center-single-column
    // You can customize the widths that "switch-preset-column-width" (Mod+R) toggles between.
    preset-column-widths {
        // Proportion sets the width as a fraction of the output width, taking gaps into account.
        // For example, you can perfectly fit four windows sized "proportion 0.25" on an output.
        // The default preset widths are 1/3, 1/2 and 2/3 of the output.
        proportion 0.5
        proportion 0.66667
        proportion 1.0
        // Fixed sets the width in logical pixels exactly.
        // fixed 1920
    }
    // You can also customize the heights that "switch-preset-window-height" (Mod+Shift+R) toggles between.
    // preset-window-heights { }
    // You can change the default width of the new windows.
    default-column-width { proportion 0.5; }
    // If you leave the brackets empty, the windows themselves will decide their initial width.
    // default-column-width {}
    // By default focus ring and border are rendered as a solid background rectangle
    // behind windows. That is, they will show up through semitransparent windows.
    // This is because windows using client-side decorations can have an arbitrary shape.
    //
    // If you don't like that, you should uncomment `prefer-no-csd` below.
    // Niri will draw focus ring and border *around* windows that agree to omit their
    // client-side decorations.
    //
    // Alternatively, you can override it with a window rule called
    // `draw-border-with-background`.
    border {
        width 1
        active-color "#cba6f7"
        inactive-color "#45475a"
        urgent-color "#f5c2e7"
    }
    focus-ring {
	off
        width 2
        active-color   "#808080"      // Medium gray
        inactive-color "#505050"      // Dark gray
    }
    shadow {
        softness 30
        spread 5
        offset x=0 y=5
        color "#0007"
    }
    struts {
    }
}

environment {
  XDG_CURRENT_DESKTOP "niri"
  MOZ_ENABLE_WAYLAND "1"
  QT_QPA_PLATFORM "wayland"
  ELECTRON_OZONE_PLATFORM_HINT "wayland"
  QT_QPA_PLATFORMTHEME "gtk3"
  QT_QPA_PLATFORMTHEME_QT6 "gtk3"
  TERMINAL "kitty"
  XCURSOR_THEME "Bibata-Modern-Ice"
  XCURSOR_SIZE "24"
}

hotkey-overlay {
    skip-at-startup
}

// Screenshot configuration
// Reference: https://github.com/YaLTeR/niri/wiki/Configuration:-Miscellaneous
// Disk writes are owned by satty via dot-screenshot; niri's built-in path is
// disabled so stray `niri msg action screenshot` calls don't litter disk.
screenshot-path null

// ============================================================================
// Window Rules - Assign applications to specific workspaces
// ============================================================================
// Reference: https://github.com/YaLTeR/niri/wiki/Configuration:-Window-Rules

// ----------------------------------------------------------------------------
// App-id matching note: Wayland app-id is case-sensitive in niri's `match`.
// `(?i)^name$` is used for any app whose StartupWMClass / actual app-id is
// mixed-case (Bruno, Ferdium, Polypane, Paseo, Chromium-browser, Alacritty).
// Lowercase-only app-ids match literally.
// ----------------------------------------------------------------------------

// === Terminal Workspace — terminals + Paseo ===
window-rule {
    match app-id="kitty"
    open-on-workspace "Terminal"
}

window-rule {
    match app-id="(?i)^alacritty$"
    open-on-workspace "Terminal"
}

window-rule {
    match app-id="gnome-terminal-server"
    open-on-workspace "Terminal"
}

// Paseo lives here per Dimitri's grouping. It is a regular GUI window, not a
// TUI — revisit if it ends up tiling awkwardly alongside kitty in practice.
window-rule {
    match app-id="(?i)^paseo$"
    open-on-workspace "Terminal"
}

// === Browser Workspace — all rendering engines including Polypane ===
window-rule {
    match app-id="zen"
    open-on-workspace "Browser"
}

window-rule {
    match app-id="firefox"
    open-on-workspace "Browser"
}

window-rule {
    match app-id="(?i)^chromium(-browser)?$"
    open-on-workspace "Browser"
    open-focused true
}

window-rule {
    match app-id="qutebrowser"
    open-on-workspace "Browser"
}

window-rule {
    match app-id="helium"
    open-on-workspace "Browser"
}

window-rule {
    match app-id="(?i)^polypane$"
    open-on-workspace "Browser"
}

// === Editor Workspace — Zed + VS Code ===
// Zed's .desktop has empty StartupWMClass; dev.zed.Zed is the convention.
// VERIFY post-launch: `niri msg windows | grep -A1 zed` — adjust if it
// reports something else (e.g. `Zed`, `zeditor`).
window-rule {
    match app-id="(?i)^dev.zed.zed$"
    open-on-workspace "Editor"
}

window-rule {
    match app-id="(?i)^code$"
    open-on-workspace "Editor"
}

// === Tools Workspace — DB / API / cloud-storage clients ===
window-rule {
    match app-id="(?i)^beekeeper-studio$"
    open-on-workspace "Tool"
}

window-rule {
    match app-id="(?i)^bruno$"
    open-on-workspace "Tool"
}

window-rule {
    match app-id="storageexplorer"
    open-on-workspace "Tool"
}

// === Chat Workspace — sync communications ===
window-rule {
    match app-id="(?i)^teams-for-linux$"
    open-on-workspace "Chat"
}

window-rule {
    match app-id="(?i)^ferdium$"
    open-on-workspace "Chat"
}

window-rule {
    match app-id="legcord"
    open-on-workspace "Chat"
}

// === Notes Workspace — knowledge management ===
window-rule {
    match app-id="obsidian"
    open-on-workspace "Note"
}

window-rule {
    match app-id="anytype"
    open-on-workspace "Note"
}

// Satty (screenshot annotator) opens as a floating window centered on the
// current workspace so it never tiles into the active column layout.
// min-width/min-height ensure the editor is usable even when capturing
// tiny regions (e.g. a single button).
window-rule {
    match app-id=r#"^com\.gabm\.satty$"#
    open-floating true
    min-width 730
    min-height 300
}

// LocalSend opens as a floating window on the current workspace.
// .desktop has empty StartupWMClass — VERIFY post-launch with
// `niri msg windows | grep -B1 -i localsend` and adjust if needed.
window-rule {
    match app-id="(?i)^localsend$"
    open-floating true
}

// === Default window styling (matches Noctalia's recommended corner radius) ===
window-rule {
    geometry-corner-radius 10
    clip-to-geometry true
    draw-border-with-background false
}

// ============================================================================
// Noctalia integration
// Reference: https://docs.noctalia.dev/v4/getting-started/compositor-settings/niri/
// ============================================================================

// Let Noctalia trigger window activation and notifications.
debug {
    honor-xdg-activation-with-invalid-serial
}

