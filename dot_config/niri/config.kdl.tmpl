{{- $hardwareModel := output "cat" "/sys/class/dmi/id/product_name" | trim -}}

// Auto-start Noctalia v5 (Wayland shell: bar + launcher + notifications + OSD + lock)
spawn-at-startup "noctalia"

// Polkit authentication agent (mate-polkit). niri ships no agent of its own;
// GUI apps that invoke pkexec (vibe-typer setup, etc.) fail without this.
spawn-at-startup "/usr/libexec/polkit-mate-authentication-agent-1"

// Vibe Typer voice dictation. Two non-obvious flags:
//   --password-store=gnome-libsecret forces Electron's safeStorage to use
//     gnome-keyring (so the saved login token can be decrypted). We use
//     this flag INSTEAD OF env XDG_CURRENT_DESKTOP=niri:GNOME because
//     when Electron sees "GNOME" in XDG_CURRENT_DESKTOP it switches its
//     tray-icon path from raw IconPixmap (noctalia renders correctly) to
//     IconThemePath+IconName (a flat /tmp/...status_icon_0.png that
//     noctalia's SNI host cannot find, fallback = hamburger glyph).
//     The --password-store flag flips the keyring backend without
//     touching the desktop hint, so both keyring AND tray icon work.
//   --autostart tells vibe-typer to start minimized in the tray rather
//     than opening its main window.
// 3s sleep gives systemd-user time to finish starting gnome-keyring's
// secret service before vibe-typer tries to decrypt its saved auth
// token. Without it, vibe-typer races the daemon and silently exits.
// (The shell wrapper is also what lets $HOME expand; niri's
// spawn-at-startup forks/execs directly with no shell.)
spawn-at-startup "sh" "-c" "sleep 3 && exec \"$HOME/Applications/VibeTyper.AppImage\" --password-store=gnome-libsecret --autostart"
{{ if .hasFingerprintReader }}
// Fingerprint lockscreen stack: swayidle drives screen-off / hyprlock / suspend.
// noctalia's own idle handlers are disabled on these machines (see
// dot_config/noctalia/config.toml.tmpl).
spawn-at-startup "niri-idle-daemon.sh"
{{ end -}}

workspace "Terminal"
workspace "Browser"
workspace "Editor"
workspace "Tool"
workspace "Chat"
workspace "Note"
workspace "Misc"

// ============================================================================
// Global behavior
// ============================================================================

// Ask apps to drop their own client-side decorations so niri's focus ring is
// the single visual source of truth for window edges. Apps must be relaunched
// to pick up the change.
prefer-no-csd

// Input device configuration. caps:swapescape intentionally omitted -- adopt
// later if you ever want vim-style caps-as-escape.
input {
    keyboard {
        repeat-delay 200
        repeat-rate 40
    }
    touchpad {
        tap
        accel-profile "flat"
    }
    mouse {
        accel-profile "flat"
        accel-speed 0.75
        scroll-factor 2.0
    }
}

// Disable hot-corner overview trigger (mousing to top-left). Keep the chorded
// Mod+O binding as the only way to reach overview.
gestures {
    hot-corners {
        off
    }
}

// Define keybindings
binds {
    // === Session & Overview ===
    Ctrl+Alt+Delete hotkey-overlay-title=null { quit; }
    Mod+Shift+Slash hotkey-overlay-title="Show hotkey overlay" { show-hotkey-overlay; }
    // Searchable keybinding cheatsheet — floating kitty + fzf over the parsed
    // niri config (see dot_local/bin/scripts/executable_niri-cheatsheet and the
    // window-rule below matching app-id="cheatsheet").
    Mod+Slash hotkey-overlay-title="fzf: search keybindings" { spawn "kitty" "--class" "cheatsheet" "--" "niri-cheatsheet"; }
    // Searchable bash aliases + functions cheatsheet — same pattern as the
    // niri keybind search, but for shell shortcuts. See
    // dot_local/bin/scripts/executable_niri-shell-cheatsheet and the
    // window-rule for app-id="shell-cheatsheet".
    Mod+A hotkey-overlay-title="fzf: search bash aliases & functions" { spawn "kitty" "--class" "shell-cheatsheet" "--" "niri-shell-cheatsheet"; }
    // fpass popup — pick a pass(1) entry and copy the password to clipboard.
    Mod+P hotkey-overlay-title="fzf: pick pass entry → copy password" { spawn "kitty" "--class" "fpass-popup" "--" "niri-fpass-popup"; }
    // fssh popup — pick an SSH host and open a new kitty connected to it.
    Mod+G hotkey-overlay-title="fzf: pick SSH host → open kitty" { spawn "kitty" "--class" "fssh-popup" "--" "niri-fssh-popup"; }
    // fabric popup — pipe input through one or more fabric patterns, with
    // per-pattern variable prompts (zenity), and copy result to clipboard.
    // The popup script never exits on its own (it `exec sleep infinity`s at
    // the end), so kitty stays open until Ctrl+Shift+W. We don't use kitty's
    // `--hold` because in some kitty versions a held window briefly closes
    // before re-rendering, which on niri exposes whatever sits behind it
    // (e.g. the zellij-main pane) and looks like a spontaneous respawn.
    Mod+F hotkey-overlay-title="fzf+fabric: pick pattern(s) → run → copy" { spawn "kitty" "--class" "fabric-popup" "--" "niri-fabric-popup"; }
    // kondo popup — pick a scan root via fzf, then kondo TUI cleans build
    // dirs (node_modules, target/, .venv, .gradle, …) interactively.
    Mod+C hotkey-overlay-title="fzf+kondo: pick scan root → clean build dirs" { spawn "kitty" "--class" "kondo-popup" "--" "niri-kondo-popup"; }
    // Zellij session switcher — opens zellij's built-in floating Session
    // Manager plugin INSIDE the focused kitty's zellij session. Requires:
    //   (1) focused niri window is kitty, (2) that kitty has a zellij
    //   client running inside. Otherwise emits a notification and exits.
    // See dot_local/bin/executable_zellij-switch for the eligibility checks.
    Mod+Z hotkey-overlay-title="fzf: switch zellij session (in focused kitty)" { spawn "zellij-switch"; }
    // Window switcher — fzf over `niri msg windows`. See
    // dot_local/bin/executable_niri-window-switch and the window-rule for
    // app-id="window-switcher".
    Mod+T hotkey-overlay-title="fzf: switch focused window" { spawn "kitty" "--class" "window-switcher" "--" "niri-window-switch"; }
    Mod+O hotkey-overlay-title="Toggle overview" { toggle-overview; }
    // Escape hatch for apps that grab keyboard shortcuts (Looking Glass,
    // Moonlight, remote-desktop, software KVM). allow-inhibiting=false makes
    // niri always process this chord even when an inhibitor is active.
    Mod+Escape allow-inhibiting=false hotkey-overlay-title="Toggle keyboard-shortcut inhibitor (always processed)" { toggle-keyboard-shortcuts-inhibit; }

    // === Launchers & Shell ===
    Mod+Return hotkey-overlay-title="Pick a Zellij session: Enter → main, 1-9 → sessionN" { spawn "kitty-zellij-pick"; }
    Mod+Space        hotkey-overlay-title="Run an Application: Noctalia launcher" { spawn "noctalia" "msg" "panel-toggle" "launcher"; }
    Mod+Shift+V      hotkey-overlay-title="Clipboard history" { spawn "noctalia" "msg" "panel-toggle" "clipboard"; }
    {{- if .hasFingerprintReader }}
    Ctrl+Alt+L hotkey-overlay-title="Lock Screen (hyprlock + fingerprint)" { spawn "hyprlock"; }
    {{- else }}
    Ctrl+Alt+L hotkey-overlay-title="Lock Screen" { spawn "noctalia" "msg" "screen-lock"; }
    {{- end }}
    Mod+Backspace  hotkey-overlay-title="Session menu" { spawn "noctalia" "msg" "panel-toggle" "session"; }
    Mod+Ctrl+Space hotkey-overlay-title="Toggle Noctalia bar" { spawn "noctalia" "msg" "bar-toggle"; }
    // Mod+Shift+N for notification history: noctalia v5's CLI does not yet expose
    // a command for notifications.toggleHistory() — only the underlying QML IPC
    // handler exists. Reinstate this binding once `noctalia msg` adds it (e.g.
    // `notification-toggle-history`) or once `qs` (Quickshell) is on PATH.
    XF86Calculator hotkey-overlay-title=null { spawn "galculator"; }

    // === Voice Dictation (Vibe Typer) ===
    // Vibe Typer registers its own global hotkey internally (configured in its
    // settings UI). Niri keybinding only needed if you want compositor-level
    // forwarding — left unbound for now. Configure the in-app hotkey to e.g.
    // XF86Favorites (the ThinkPad star key) via Vibe Typer's preferences.

    // === Volume Controls (F2/F3/F4) — Noctalia provides the OSD ===
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "volume-up"; }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "volume-down"; }
    XF86AudioMute        allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "volume-mute"; }
    XF86AudioMicMute     allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "mic-mute"; }

    // Workaround for wireplumber 0.5.x bug where bluez audio monitor silently fails
    // after a leaked-proxy shutdown; restart wireplumber + cycle any connected BT
    // audio devices so PipeWire re-creates the sink. See scripts/fix-bt-audio.
    Mod+Shift+B hotkey-overlay-title="Fix BT audio (restart wireplumber + reconnect)" { spawn "fix-bt-audio"; }

    // === Mouse Live-Tune (niri-mouse-tune edits both rendered + chezmoi source) ===
    Mod+Ctrl+Equal       hotkey-overlay-title="Mouse: accel-speed +0.10"  { spawn "niri-mouse-tune" "accel" "up"; }
    Mod+Ctrl+Minus       hotkey-overlay-title="Mouse: accel-speed -0.10"  { spawn "niri-mouse-tune" "accel" "down"; }
    Mod+Ctrl+Period      hotkey-overlay-title="Mouse: scroll-factor +0.25" { spawn "niri-mouse-tune" "scroll" "up"; }
    Mod+Ctrl+Comma       hotkey-overlay-title="Mouse: scroll-factor -0.25" { spawn "niri-mouse-tune" "scroll" "down"; }

    // === Brightness Controls (F5/F6) — via Noctalia ===
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "brightness-down"; }
    XF86MonBrightnessUp   allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "brightness-up"; }

    // === Media Player Controls (F7 = play/pause on most ThinkPads) ===
    XF86AudioNext  allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "next"; }
    XF86AudioPause allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "toggle"; }
    XF86AudioPlay  allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "toggle"; }
    XF86AudioPrev  allow-when-locked=true hotkey-overlay-title=null { spawn "noctalia" "msg" "media" "previous"; }

    // === Wireless Controls (F8 = WiFi, F10 = Bluetooth) ===
    // v5 IPC doesn't expose wifi/bluetooth toggles yet; use system tools directly.
    XF86Bluetooth hotkey-overlay-title=null { spawn "bash" "-c" "bluetoothctl show | grep -q 'Powered: yes' && bluetoothctl power off || bluetoothctl power on"; }
    XF86WLAN      hotkey-overlay-title=null      { spawn "nmcli" "radio" "wifi"; }

    // === Window Management ===
    Mod+Q repeat=false hotkey-overlay-title=null { close-window; }
    Mod+Alt+F   hotkey-overlay-title="Maximize column" { maximize-column; }
    Mod+Shift+F hotkey-overlay-title="Full screen window" { fullscreen-window; }
    Mod+W       hotkey-overlay-title="Toggle floating window" { toggle-window-floating; }
    Mod+Ctrl+W  hotkey-overlay-title="Switch focus between floating and tiling" { switch-focus-between-floating-and-tiling; }
    Mod+V       hotkey-overlay-title="Toggle tabbed column" { toggle-column-tabbed-display; }
    Mod+I       hotkey-overlay-title="Focus previously focused window" { focus-window-previous; }

    // === Focus Navigation ===
    Mod+Down  hotkey-overlay-title="Focus window down" { focus-window-down; }
    Mod+Up    hotkey-overlay-title="Focus window up" { focus-window-up; }
    Mod+H     hotkey-overlay-title=null { focus-column-left; }
    Mod+L     hotkey-overlay-title=null { focus-column-right; }
    // Mod+J / Mod+K are bound to workspace navigation below.

    // === Window Movement ===
    Mod+Shift+Down  hotkey-overlay-title="Move window down" { move-window-down; }
    Mod+Shift+Up    hotkey-overlay-title="Move window up" { move-window-up; }
    Mod+Shift+H     hotkey-overlay-title=null { move-column-left; }
    // Mod+Shift+J / Mod+Shift+K are bound to move-workspace below.
    Mod+Shift+L     hotkey-overlay-title=null { move-column-right; }

    // === Column Navigation ===
    Mod+Home      hotkey-overlay-title="Focus first column" { focus-column-first; }
    Mod+End       hotkey-overlay-title="Focus last column" { focus-column-last; }

    // === Monitor Navigation ===
    //Mod+Ctrl+Down  { focus-monitor-down; }
    //Mod+Ctrl+Up    { focus-monitor-up; }
    Mod+Ctrl+H     hotkey-overlay-title="Focus left monitor" { focus-monitor-left; }
    Mod+Ctrl+J     hotkey-overlay-title="Focus lower monitor" { focus-monitor-down; }
    Mod+Ctrl+K     hotkey-overlay-title="Focus upper monitor" { focus-monitor-up; }
    Mod+Ctrl+L     hotkey-overlay-title="Focus right monitor" { focus-monitor-right; }

    // === Move to Monitor ===
    Mod+Shift+Ctrl+H     hotkey-overlay-title="Move column to left monitor" { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J     hotkey-overlay-title="Move column to lower monitor" { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K     hotkey-overlay-title="Move column to upper monitor" { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L     hotkey-overlay-title="Move column to right monitor" { move-column-to-monitor-right; }

    // === Workspace Navigation ===
    Mod+J             hotkey-overlay-title=null { focus-workspace-down; }
    Mod+K             hotkey-overlay-title=null { focus-workspace-up; }
    Mod+Ctrl+Alt+Down hotkey-overlay-title="Move column to next workspace" { move-column-to-workspace-down; }
    Mod+Ctrl+Alt+Up   hotkey-overlay-title="Move column to previous workspace" { move-column-to-workspace-up; }

    // === Move Workspaces ===
    Mod+Shift+J         hotkey-overlay-title=null { move-workspace-down; }
    Mod+Shift+K         hotkey-overlay-title=null { move-workspace-up; }

        // === Numbered Workspaces ===
    Mod+1 hotkey-overlay-title=null { focus-workspace "Terminal"; }
    Mod+2 hotkey-overlay-title=null  { focus-workspace "Browser"; }
    Mod+3 hotkey-overlay-title=null   { focus-workspace "Editor"; }
    Mod+4 hotkey-overlay-title=null     { focus-workspace "Tool"; }
    Mod+5 hotkey-overlay-title=null     { focus-workspace "Chat"; }
    Mod+6 hotkey-overlay-title=null     { focus-workspace "Note"; }
    Mod+7 hotkey-overlay-title=null     { focus-workspace "Misc"; }
    Mod+8 hotkey-overlay-title=null        { focus-workspace 8; }
    Mod+9 hotkey-overlay-title=null        { focus-workspace 9; }

    // === Move to Numbered Workspaces ===
    Mod+Shift+1 hotkey-overlay-title=null { move-column-to-workspace "Terminal"; }
    Mod+Shift+2 hotkey-overlay-title=null  { move-column-to-workspace "Browser"; }
    Mod+Shift+3 hotkey-overlay-title=null   { move-column-to-workspace "Editor"; }
    Mod+Shift+4 hotkey-overlay-title=null     { move-column-to-workspace "Tool"; }
    Mod+Shift+5 hotkey-overlay-title=null     { move-column-to-workspace "Chat"; }
    Mod+Shift+6 hotkey-overlay-title=null     { move-column-to-workspace "Note"; }
    Mod+Shift+7 hotkey-overlay-title=null     { move-column-to-workspace "Misc"; }
    Mod+Shift+8 hotkey-overlay-title=null        { move-column-to-workspace 8; }
    Mod+Shift+9 hotkey-overlay-title=null        { move-column-to-workspace 9; }

    // === Column Management ===
    Mod+BracketLeft  hotkey-overlay-title="Consume or expel window left" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Consume or expel window right" { consume-or-expel-window-right; }
    Mod+Comma        hotkey-overlay-title="Consume right window into column" { consume-window-into-column; }
    Mod+Period       hotkey-overlay-title="Expel bottom window from column" { expel-window-from-column; }

    // === Sizing & Layout ===
    Mod+R       hotkey-overlay-title="Cycle preset column widths" { switch-preset-column-width; }
    Mod+Shift+R hotkey-overlay-title="Cycle preset window heights" { switch-preset-window-height; }
    Mod+Ctrl+R  hotkey-overlay-title="Reset window height" { reset-window-height; }
    Mod+Ctrl+F  hotkey-overlay-title="Expand column to available width" { expand-column-to-available-width; }
    Mod+Ctrl+C  hotkey-overlay-title="Center column" { center-column; }

    // === Manual Sizing ===
    Mod+Minus       hotkey-overlay-title="Decrease column width" { set-column-width "-10%"; }
    Mod+Equal       hotkey-overlay-title="Increase column width" { set-column-width "+10%"; }
    Mod+Shift+Minus hotkey-overlay-title="Decrease window height" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Increase window height" { set-window-height "+10%"; }

    // === Screenshots ===
    // All chords pipe grim/niri capture into satty for annotation. The satty
    // binary is installed by .chezmoiscripts/run_onchange_after_04-install-satty.
    // No native niri-screenshot fallback by design -- if satty breaks, run
    // `dot-screenshot region > /tmp/x.png` from a terminal.
    Mod+S            hotkey-overlay-title="Screenshot (region)"           { spawn "dot-screenshot" "region"; }
    Mod+Shift+S      hotkey-overlay-title="Screenshot (window)"           { spawn "dot-screenshot" "window"; }
    Mod+Ctrl+S       hotkey-overlay-title="Screenshot (monitor: focused)" { spawn "dot-screenshot" "monitor-focused"; }
    Mod+Ctrl+Shift+S hotkey-overlay-title="Screenshot (monitor: all)"     { spawn "dot-screenshot" "monitor-all"; }

    // === Workspace Management ===
    Mod+Shift+M hotkey-overlay-title="Move workspaces to LG" { spawn "bash" "-c" "$HOME/.local/bin/scripts/toggle-workspaces --to-lg"; }
}

