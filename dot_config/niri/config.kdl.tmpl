// LG Electronics LG HDR WQHD external monitor (3440x1440) at top
// Internal display (2560x1600 scaled to 1.25) centered below

output "LG Electronics LG HDR WQHD 107NTNH4K559" {
    mode "3440x1440@59.97"
    position x=0 y=0
    scale 1.0
}

output "eDP-1" {
    mode "2560x1600@90"
    position x=664 y=1440
    scale 1.25
