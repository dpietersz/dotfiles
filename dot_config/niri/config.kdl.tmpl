{{- $hardwareModel := output "cat" "/sys/class/dmi/id/product_name" | trim -}}

// Auto-start Noctalia v5 (Wayland shell: bar + launcher + notifications + OSD + lock)
spawn-at-startup "noctalia"

// Polkit authentication agent (mate-polkit). niri ships no agent of its own;
// GUI apps that invoke pkexec (vibe-typer setup, etc.) fail without this.
spawn-at-startup "/usr/libexec/polkit-mate-authentication-agent-1"

// Vibe Typer voice dictation, with a 5s prelaunch delay so noctalia's
// StatusNotifierItem host is registered BEFORE vibe-typer announces its
// tray icon. Without the delay, noctalia falls back to a generic glyph
// (hamburger). systemd-xdg-autostart-generator (which would normally run
// the XDG .desktop) does NOT honor X-GNOME-Autostart-Delay, so the XDG
// autostart file is marked Hidden=true and we launch vibe-typer here via
// shell instead. The 5s also covers gnome-keyring becoming reachable.
spawn-at-startup "sh" "-c" "sleep 5 && exec env XDG_CURRENT_DESKTOP=niri:GNOME \"$HOME/Applications/VibeTyper.AppImage\" --autostart"
{{ if .hasFingerprintReader }}
// Fingerprint lockscreen stack: swayidle drives screen-off / hyprlock / suspend.
// noctalia's own idle handlers are disabled on these machines (see
// dot_config/noctalia/config.toml.tmpl).
spawn-at-startup "niri-idle-daemon.sh"
{{ end -}}

workspace "Terminal"
workspace "Browser"
workspace "Editor"
workspace "Tool"
workspace "Chat"
workspace "Note"
workspace "Misc"

// ============================================================================
// Global behavior
// ============================================================================

// Ask apps to drop their own client-side decorations so niri's focus ring is
// the single visual source of truth for window edges. Apps must be relaunched
// to pick up the change.
prefer-no-csd

// Input device configuration. caps:swapescape intentionally omitted -- adopt
// later if you ever want vim-style caps-as-escape.
input {
    keyboard {
        repeat-delay 200
        repeat-rate 40
    }
    touchpad {
        tap
        accel-profile "flat"
    }
    mouse {
        accel-profile "flat"
        scroll-factor 2.0
    }
}

// Disable hot-corner overview trigger (mousing to top-left). Keep the chorded
// Mod+O binding as the only way to reach overview.
gestures {
    hot-corners {
        off
    }
}

// Define keybindings
binds {
    // === Session & Overview ===
    Ctrl+Alt+Delete hotkey-overlay-title="Exit niri session" { quit; }
    Mod+Shift+Slash hotkey-overlay-title="Show hotkey overlay" { show-hotkey-overlay; }
    Mod+O hotkey-overlay-title="Toggle overview" { toggle-overview; }
    // Escape hatch for apps that grab keyboard shortcuts (Looking Glass,
    // Moonlight, remote-desktop, software KVM). allow-inhibiting=false makes
    // niri always process this chord even when an inhibitor is active.
    Mod+Escape allow-inhibiting=false hotkey-overlay-title="Toggle keyboard-shortcut inhibitor (always processed)" { toggle-keyboard-shortcuts-inhibit; }

    // === Launchers & Shell ===
    Mod+Return       hotkey-overlay-title="Open a Terminal: kitty + zellij" { spawn "kitty-zellij"; }
    Mod+Shift+Return hotkey-overlay-title="Open main Zellij session in kitty" { spawn "kitty-zellij-main"; }
    Mod+Space        hotkey-overlay-title="Run an Application: Noctalia launcher" { spawn "noctalia" "msg" "panel-toggle" "launcher"; }
    Mod+Shift+V      hotkey-overlay-title="Clipboard history" { spawn "noctalia" "msg" "panel-toggle" "clipboard"; }
    {{- if .hasFingerprintReader }}
    Ctrl+Alt+L hotkey-overlay-title="Lock Screen (hyprlock + fingerprint)" { spawn "hyprlock"; }
    {{- else }}
    Ctrl+Alt+L hotkey-overlay-title="Lock Screen" { spawn "noctalia" "msg" "screen-lock"; }
    {{- end }}
    Mod+Backspace  hotkey-overlay-title="Session menu" { spawn "noctalia" "msg" "panel-toggle" "session"; }
    Mod+Ctrl+Space hotkey-overlay-title="Toggle Noctalia bar" { spawn "noctalia" "msg" "bar-toggle"; }
    Mod+N          hotkey-overlay-title="Control center / notifications" { spawn "noctalia" "msg" "panel-toggle" "control-center"; }
    // Mod+Shift+N for notification history: noctalia v5's CLI does not yet expose
    // a command for notifications.toggleHistory() — only the underlying QML IPC
    // handler exists. Reinstate this binding once `noctalia msg` adds it (e.g.
    // `notification-toggle-history`) or once `qs` (Quickshell) is on PATH.
    XF86Calculator hotkey-overlay-title="Calculator: galculator" { spawn "galculator"; }
    Mod+B          hotkey-overlay-title="Open Helium Browser" { spawn "helium-browser-bin"; }

    // === Voice Dictation (Vibe Typer) ===
    // Vibe Typer registers its own global hotkey internally (configured in its
    // settings UI). Niri keybinding only needed if you want compositor-level
    // forwarding — left unbound for now. Configure the in-app hotkey to e.g.
    // XF86Favorites (the ThinkPad star key) via Vibe Typer's preferences.

    // === Volume Controls (F2/F3/F4) — Noctalia provides the OSD ===
    XF86AudioRaiseVolume allow-when-locked=true hotkey-overlay-title="Raise volume" { spawn "noctalia" "msg" "volume-up"; }
    XF86AudioLowerVolume allow-when-locked=true hotkey-overlay-title="Lower volume" { spawn "noctalia" "msg" "volume-down"; }
    XF86AudioMute        allow-when-locked=true hotkey-overlay-title="Mute playback" { spawn "noctalia" "msg" "volume-mute"; }
    XF86AudioMicMute     allow-when-locked=true hotkey-overlay-title="Mute microphone" { spawn "noctalia" "msg" "mic-mute"; }

    // === Brightness Controls (F5/F6) — via Noctalia ===
    XF86MonBrightnessDown allow-when-locked=true hotkey-overlay-title="Decrease brightness" { spawn "noctalia" "msg" "brightness-down"; }
    XF86MonBrightnessUp   allow-when-locked=true hotkey-overlay-title="Increase brightness" { spawn "noctalia" "msg" "brightness-up"; }

    // === Media Player Controls (F7 = play/pause on most ThinkPads) ===
    XF86AudioNext  allow-when-locked=true hotkey-overlay-title="Next track" { spawn "noctalia" "msg" "media" "next"; }
    XF86AudioPause allow-when-locked=true hotkey-overlay-title="Pause / play track" { spawn "noctalia" "msg" "media" "toggle"; }
    XF86AudioPlay  allow-when-locked=true hotkey-overlay-title="Play / pause track" { spawn "noctalia" "msg" "media" "toggle"; }
    XF86AudioPrev  allow-when-locked=true hotkey-overlay-title="Previous track" { spawn "noctalia" "msg" "media" "previous"; }

    // === Wireless Controls (F8 = WiFi, F10 = Bluetooth) ===
    // v5 IPC doesn't expose wifi/bluetooth toggles yet; use system tools directly.
    XF86Bluetooth hotkey-overlay-title="Toggle Bluetooth" { spawn "bash" "-c" "bluetoothctl show | grep -q 'Powered: yes' && bluetoothctl power off || bluetoothctl power on"; }
    XF86WLAN      hotkey-overlay-title="Toggle WiFi"      { spawn "nmcli" "radio" "wifi"; }

    // === Window Management ===
    Mod+Q repeat=false hotkey-overlay-title="Close window" { close-window; }
    Mod+Alt+F   hotkey-overlay-title="Maximize column" { maximize-column; }
    Mod+Shift+F hotkey-overlay-title="Full screen window" { fullscreen-window; }
    Mod+W       hotkey-overlay-title="Toggle floating window" { toggle-window-floating; }
    Mod+Ctrl+W  hotkey-overlay-title="Switch focus between floating and tiling" { switch-focus-between-floating-and-tiling; }
    Mod+V       hotkey-overlay-title="Toggle tabbed column" { toggle-column-tabbed-display; }
    Mod+I       hotkey-overlay-title="Focus previously focused window" { focus-window-previous; }

    // === Focus Navigation ===
    Mod+Left  hotkey-overlay-title="Focus column left" { focus-column-left; }
    Mod+Down  hotkey-overlay-title="Focus window down" { focus-window-down; }
    Mod+Up    hotkey-overlay-title="Focus window up" { focus-window-up; }
    Mod+Right hotkey-overlay-title="Focus column right" { focus-column-right; }
    Mod+H     hotkey-overlay-title="Focus column left" { focus-column-left; }
    // Mod+J / Mod+K are bound to workspace navigation below.
    Mod+L     hotkey-overlay-title="Focus column right" { focus-column-right; }

    // === Window Movement ===
    Mod+Shift+Left  hotkey-overlay-title="Move column left" { move-column-left; }
    Mod+Shift+Down  hotkey-overlay-title="Move window down" { move-window-down; }
    Mod+Shift+Up    hotkey-overlay-title="Move window up" { move-window-up; }
    Mod+Shift+Right hotkey-overlay-title="Move column right" { move-column-right; }
    Mod+Shift+H     hotkey-overlay-title="Move column left" { move-column-left; }
    // Mod+Shift+J / Mod+Shift+K are bound to move-workspace below.
    Mod+Shift+L     hotkey-overlay-title="Move column right" { move-column-right; }

    // === Column Navigation ===
    Mod+Home      hotkey-overlay-title="Focus first column" { focus-column-first; }
    Mod+End       hotkey-overlay-title="Focus last column" { focus-column-last; }
    Mod+Ctrl+Home hotkey-overlay-title="Move column to first" { move-column-to-first; }
    Mod+Ctrl+End  hotkey-overlay-title="Move column to last" { move-column-to-last; }

    // === Monitor Navigation ===
    Mod+Ctrl+Left  hotkey-overlay-title="Focus left monitor" { focus-monitor-left; }
    //Mod+Ctrl+Down  { focus-monitor-down; }
    //Mod+Ctrl+Up    { focus-monitor-up; }
    Mod+Ctrl+Right hotkey-overlay-title="Focus right monitor" { focus-monitor-right; }
    Mod+Ctrl+H     hotkey-overlay-title="Focus left monitor" { focus-monitor-left; }
    Mod+Ctrl+J     hotkey-overlay-title="Focus lower monitor" { focus-monitor-down; }
    Mod+Ctrl+K     hotkey-overlay-title="Focus upper monitor" { focus-monitor-up; }
    Mod+Ctrl+L     hotkey-overlay-title="Focus right monitor" { focus-monitor-right; }

    // === Move to Monitor ===
    Mod+Shift+Ctrl+Left  hotkey-overlay-title="Move column to left monitor" { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+Down  hotkey-overlay-title="Move column to lower monitor" { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+Up    hotkey-overlay-title="Move column to upper monitor" { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+Right hotkey-overlay-title="Move column to right monitor" { move-column-to-monitor-right; }
    Mod+Shift+Ctrl+H     hotkey-overlay-title="Move column to left monitor" { move-column-to-monitor-left; }
    Mod+Shift+Ctrl+J     hotkey-overlay-title="Move column to lower monitor" { move-column-to-monitor-down; }
    Mod+Shift+Ctrl+K     hotkey-overlay-title="Move column to upper monitor" { move-column-to-monitor-up; }
    Mod+Shift+Ctrl+L     hotkey-overlay-title="Move column to right monitor" { move-column-to-monitor-right; }

    // === Workspace Navigation ===
    Mod+J             hotkey-overlay-title="Focus next workspace" { focus-workspace-down; }
    Mod+K             hotkey-overlay-title="Focus previous workspace" { focus-workspace-up; }
    Mod+Ctrl+Down     hotkey-overlay-title="Focus next workspace" { focus-workspace-down; }
    Mod+Ctrl+Up       hotkey-overlay-title="Focus previous workspace" { focus-workspace-up; }
    Mod+Ctrl+Alt+Down hotkey-overlay-title="Move column to next workspace" { move-column-to-workspace-down; }
    Mod+Ctrl+Alt+Up   hotkey-overlay-title="Move column to previous workspace" { move-column-to-workspace-up; }

    // === Move Workspaces ===
    Mod+Shift+Page_Down hotkey-overlay-title="Move workspace down" { move-workspace-down; }
    Mod+Shift+Page_Up   hotkey-overlay-title="Move workspace up" { move-workspace-up; }
    Mod+Shift+J         hotkey-overlay-title="Move workspace down" { move-workspace-down; }
    Mod+Shift+K         hotkey-overlay-title="Move workspace up" { move-workspace-up; }

    // === Mouse Wheel Navigation ===
    Mod+WheelScrollDown      cooldown-ms=150 hotkey-overlay-title="Focus next workspace" { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 hotkey-overlay-title="Focus previous workspace" { focus-workspace-up; }
    Mod+Ctrl+WheelScrollDown cooldown-ms=150 hotkey-overlay-title="Move column to next workspace" { move-column-to-workspace-down; }
    Mod+Ctrl+WheelScrollUp   cooldown-ms=150 hotkey-overlay-title="Move column to previous workspace" { move-column-to-workspace-up; }

    Mod+WheelScrollRight      hotkey-overlay-title="Focus column right" { focus-column-right; }
    Mod+WheelScrollLeft       hotkey-overlay-title="Focus column left" { focus-column-left; }
    Mod+Ctrl+WheelScrollRight hotkey-overlay-title="Move column right" { move-column-right; }
    Mod+Ctrl+WheelScrollLeft  hotkey-overlay-title="Move column left" { move-column-left; }

    Mod+Shift+WheelScrollDown      hotkey-overlay-title="Focus column right" { focus-column-right; }
    Mod+Shift+WheelScrollUp        hotkey-overlay-title="Focus column left" { focus-column-left; }
    Mod+Ctrl+Shift+WheelScrollDown hotkey-overlay-title="Move column right" { move-column-right; }
    Mod+Ctrl+Shift+WheelScrollUp   hotkey-overlay-title="Move column left" { move-column-left; }

    // === Numbered Workspaces ===
    Mod+1 hotkey-overlay-title="Focus Terminal workspace" { focus-workspace "Terminal"; }
    Mod+2 hotkey-overlay-title="Focus Browser workspace"  { focus-workspace "Browser"; }
    Mod+3 hotkey-overlay-title="Focus Editor workspace"   { focus-workspace "Editor"; }
    Mod+4 hotkey-overlay-title="Focus Tool workspace"     { focus-workspace "Tool"; }
    Mod+5 hotkey-overlay-title="Focus Chat workspace"     { focus-workspace "Chat"; }
    Mod+6 hotkey-overlay-title="Focus Note workspace"     { focus-workspace "Note"; }
    Mod+7 hotkey-overlay-title="Focus Misc workspace"     { focus-workspace "Misc"; }
    Mod+8 hotkey-overlay-title="Focus workspace 8"        { focus-workspace 8; }
    Mod+9 hotkey-overlay-title="Focus workspace 9"        { focus-workspace 9; }

    // === Move to Numbered Workspaces ===
    Mod+Shift+1 hotkey-overlay-title="Move column to Terminal workspace" { move-column-to-workspace "Terminal"; }
    Mod+Shift+2 hotkey-overlay-title="Move column to Browser workspace"  { move-column-to-workspace "Browser"; }
    Mod+Shift+3 hotkey-overlay-title="Move column to Editor workspace"   { move-column-to-workspace "Editor"; }
    Mod+Shift+4 hotkey-overlay-title="Move column to Tool workspace"     { move-column-to-workspace "Tool"; }
    Mod+Shift+5 hotkey-overlay-title="Move column to Chat workspace"     { move-column-to-workspace "Chat"; }
    Mod+Shift+6 hotkey-overlay-title="Move column to Note workspace"     { move-column-to-workspace "Note"; }
    Mod+Shift+7 hotkey-overlay-title="Move column to Misc workspace"     { move-column-to-workspace "Misc"; }
    Mod+Shift+8 hotkey-overlay-title="Move column to workspace 8"        { move-column-to-workspace 8; }
    Mod+Shift+9 hotkey-overlay-title="Move column to workspace 9"        { move-column-to-workspace 9; }

    // === Column Management ===
    Mod+BracketLeft  hotkey-overlay-title="Consume or expel window left" { consume-or-expel-window-left; }
    Mod+BracketRight hotkey-overlay-title="Consume or expel window right" { consume-or-expel-window-right; }
    Mod+Comma        hotkey-overlay-title="Consume right window into column" { consume-window-into-column; }
    Mod+Period       hotkey-overlay-title="Expel bottom window from column" { expel-window-from-column; }

    // === Sizing & Layout ===
    Mod+R       hotkey-overlay-title="Cycle preset column widths" { switch-preset-column-width; }
    Mod+Shift+R hotkey-overlay-title="Cycle preset window heights" { switch-preset-window-height; }
    Mod+Ctrl+R  hotkey-overlay-title="Reset window height" { reset-window-height; }
    Mod+Ctrl+F  hotkey-overlay-title="Expand column to available width" { expand-column-to-available-width; }
    Mod+Ctrl+C  hotkey-overlay-title="Center column" { center-column; }

    // === Manual Sizing ===
    Mod+Minus       hotkey-overlay-title="Decrease column width" { set-column-width "-10%"; }
    Mod+Equal       hotkey-overlay-title="Increase column width" { set-column-width "+10%"; }
    Mod+Shift+Minus hotkey-overlay-title="Decrease window height" { set-window-height "-10%"; }
    Mod+Shift+Equal hotkey-overlay-title="Increase window height" { set-window-height "+10%"; }

    // === Screenshots ===
    // All chords pipe grim/niri capture into satty for annotation. The satty
    // binary is installed by .chezmoiscripts/run_onchange_after_04-install-satty.
    // No native niri-screenshot fallback by design -- if satty breaks, run
    // `dot-screenshot region > /tmp/x.png` from a terminal.
    Mod+S            hotkey-overlay-title="Screenshot (region)"           { spawn "dot-screenshot" "region"; }
    Mod+Shift+S      hotkey-overlay-title="Screenshot (window)"           { spawn "dot-screenshot" "window"; }
    Mod+Ctrl+S       hotkey-overlay-title="Screenshot (monitor: focused)" { spawn "dot-screenshot" "monitor-focused"; }
    Mod+Ctrl+Shift+S hotkey-overlay-title="Screenshot (monitor: all)"     { spawn "dot-screenshot" "monitor-all"; }

    // === Workspace Management ===
    Mod+Shift+M hotkey-overlay-title="Move workspaces to LG" { spawn "bash" "-c" "$HOME/.local/bin/scripts/toggle-workspaces --to-lg"; }
}

