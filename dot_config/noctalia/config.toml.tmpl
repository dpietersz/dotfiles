# Declarative Noctalia v5 config — tracked in chezmoi so all machines share it.
#
# Noctalia merges built-in defaults < this file < ~/.local/state/noctalia/settings.toml.
# The GUI Settings panel writes to the state file, NOT here, so:
#   - Edit this file by hand and `chezmoi apply` to propagate across machines.
#   - When you tweak something via the GUI and want it tracked, copy the relevant
#     section from ~/.local/state/noctalia/settings.toml into this file, then
#     remove it from state (so this file becomes authoritative).

[bar.default]
start  = ["control-center", "wallpaper", "workspaces"]
center = ["date", "clock"]
end    = ["notifications", "clipboard", "network", "bluetooth", "battery", "volume", "brightness", "session", "tray"]

[brightness]
enable_ddcutil = true

[nightlight]
enabled = true

[shell]
# Noctalia's built-in polkit agent didn't play well with Vibe Typer's
# pkexec flow — using mate-polkit (layered + spawn-at-startup in niri) instead.
polkit_agent     = false
telemetry_enabled = false

[shell.panel]
attach_clipboard = true
attach_launcher  = true

[theme]
builtin = "Gruvbox"
source  = "builtin"

[wallpaper]
# Noctalia v5's GUI only exposes the global "directory" key; the
# directory_dark / directory_light per-scheme overrides live in Advanced
# settings and weren't picked up reliably. Using the global directory matches
# the working setup on the main machine.
directory = "{{ .chezmoi.homeDir }}/dev/Pictures/Wallpapers/dark"

[wallpaper.default]
# Seed which wallpaper to show on first launch (state's [wallpaper.last] /
# [wallpaper.monitors.*] override this once the user picks something in the UI).
path = "{{ .chezmoi.homeDir }}/dev/Pictures/Wallpapers/dark/fedora-gruvbox-dark.webp"

[widget.bluetooth]
capsule    = false
show_label = false

[widget.network]
capsule    = false
show_label = false

[widget.workspaces]
display         = "name"   # "none" | "id" | "name"  — workspaces are declared as "1".."9" in niri so this shows numbers
max_label_chars = 10
hide_when_empty = true     # hides the "scratchpad" pill when its window is currently revealed to the user
{{ if .hasFingerprintReader }}
# Fingerprint lockscreen stack — see dot_config/hypr/hyprlock.conf.tmpl and
# dot_local/bin/scripts/niri-idle-daemon.sh. swayidle owns the idle chain
# (screen-off → hyprlock → suspend), so disable noctalia's parallel idle
# behaviors to prevent double-firing on the timeouts.
[idle.behavior.lock]
enabled = false

[idle.behavior.screen-off]
enabled = false

[idle.behavior.suspend]
enabled = false
{{- end }}
