# Brewfile.darwin.tmpl — macOS-only tools
#
# Runs alongside Brewfile.tmpl on macOS only.
# Folded from former run_once_before_01b-install-homebrew-packages.sh.tmpl.

# ---- taps ----
tap "nikitabobko/tap"
tap "amar1729/formulae"

# ---- core formulas (mac-only) ----
brew "gnupg"
brew "mise"             # still installed; used for per-project tools only
brew "pass"
brew "pinentry"
brew "pinentry-mac"     # native macOS passphrase dialog — used by gpg-agent
                        # (configure-gpg-pinentry script wires it in)

# ---- dev tools ----
# ghostty / kitty / zed / vscodium are Mac casks (no formula version);
# espanso is also cask-only on macOS. tailscale is a cask (CLI shipped
# inside the .app bundle and exposed by the cask installer).
cask "ghostty"
cask "kitty"
cask "zed"
cask "vscodium"
cask "espanso"
brew "browserpass"
brew "llm"
brew "tldr"

# ---- CLI extras ----
brew "ffmpeg"
brew "flyctl"
brew "railway"
brew "tmux"
brew "tree"
brew "yt-dlp"

# ---- Docker stack ----
brew "colima"
brew "docker"
brew "docker-buildx"
brew "docker-credential-helper"

# ---- Java / Android (mac) ----
cask "temurin@17"                 # was mise java=temurin-17
cask "android-commandlinetools"   # was mise android-sdk=20.0
cask "android-platform-tools"     # adb/fastboot

# ---- GUI casks ----
cask "nikitabobko/tap/aerospace"
cask "arq"
cask "azure-data-studio"
cask "beekeeper-studio"
cask "bruno"
cask "cleanmymac"
cask "displaylink"
cask "granola"
cask "legcord"
cask "microsoft-azure-storage-explorer"
cask "microsoft-teams"
cask "obsidian"
cask "polypane"
cask "rapidapi"
cask "raycast"
cask "superwhisper"
cask "syncthing-app"           # was "syncthing" — homebrew renamed
cask "tailscale-app"           # was "tailscale" — homebrew renamed
cask "ungoogled-chromium"
cask "zen"
