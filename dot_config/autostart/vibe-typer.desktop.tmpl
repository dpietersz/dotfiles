[Desktop Entry]
Type=Application
Name=Vibe Typer
Comment=Voice dictation — autostarted after graphical session is ready
# env XDG_CURRENT_DESKTOP=niri:GNOME is what lets Electron's
# KeyStorageLinux::SelectBackend pick gnome-keyring (it greps for the
# substring "GNOME") instead of the plaintext fallback. Without it the
# saved login token can't be decrypted and Vibe Typer shows the sign-in
# screen on every launch. Same trick as udx-toolbox.sh applies to its
# Electron apps.
Exec=env XDG_CURRENT_DESKTOP=niri:GNOME "{{ .chezmoi.homeDir }}/Applications/VibeTyper.AppImage" --autostart
# Hidden=true so systemd-xdg-autostart-generator skips this entry. We launch
# Vibe Typer from niri's spawn-at-startup with a 5s sleep instead, because
# the systemd generator IGNORES X-GNOME-Autostart-Delay (a gnome-session-
# only extension) and would otherwise launch vibe-typer before noctalia's
# StatusNotifierItem host is ready, causing a hamburger tray icon fallback.
# The .desktop is kept for documentation + manual launch via app launcher.
Hidden=true
Terminal=false
