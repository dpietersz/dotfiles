# hyprlock — Wayland session locker with native fprintd integration.
# Used on machines where .hasFingerprintReader is true (noctalia v5's built-in
# lockscreen does password-only PAM and can't share the sensor with fprintd
# concurrently). PAM service falls back to /etc/pam.d/system-auth, which has
# pam_fprintd.so wired via `authselect enable-feature with-fingerprint`.

general {
    grace = 2
    hide_cursor = true
    ignore_empty_input = true
    no_fade_in = false
    disable_loading_bar = false
}

# Background: simple dark color. Gruvbox dark1 to match the noctalia theme.
background {
    monitor =
    color = rgba(282828ff)
    blur_passes = 0
}

# Fingerprint authentication — the whole point of this swap.
auth {
    fingerprint {
        enabled = true
        ready_message = "Touch the fingerprint sensor or type password"
        present_message = "Verifying…"
        retry_delay = 250
    }
    pam {
        enabled = true
    }
}

# Password input field (still works as a fallback when finger fails or
# during the 10-min-locked window where hyprlock #702 stops the sensor).
input-field {
    monitor =
    size = 320, 50
    outline_thickness = 2
    dots_size = 0.25
    dots_spacing = 0.55
    outer_color = rgba(458588ff)
    inner_color = rgba(3c3836ff)
    font_color = rgba(ebdbb2ff)
    fade_on_empty = true
    placeholder_text = <i>Password or fingerprint…</i>
    fail_text = <i>$FAIL <b>($ATTEMPTS)</b></i>
    fail_color = rgba(cc241dff)
    check_color = rgba(98971aff)
    hide_input = false
    position = 0, -120
    halign = center
    valign = center
}

# Clock + hostname above the input.
label {
    monitor =
    text = cmd[update:1000] date "+%H:%M"
    color = rgba(ebdbb2ff)
    font_size = 96
    font_family = Monaspace Neon
    position = 0, 180
    halign = center
    valign = center
}

label {
    monitor =
    text = {{ .chezmoi.hostname }}
    color = rgba(a89984ff)
    font_size = 16
    font_family = Monaspace Neon
    position = 0, 80
    halign = center
    valign = center
}
