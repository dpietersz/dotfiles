// Minimal Zellij config for this dotfiles repo.
// Uses built-in Gruvbox themes, keeps default keybindings,
// and prefers a lower-chrome UI.

theme "gruvbox-dark"
theme_dark "gruvbox-dark"
theme_light "gruvbox-light"

default_layout "default"

scroll_buffer_size 20000
pane_frames false
mouse_mode true

session_serialization true
pane_viewport_serialization false

copy_on_select false
{{- if .isMacOS }}
copy_command "pbcopy"
{{- else }}
copy_command "wl-copy"
{{- end }}

// Explicit scrollback editor. Zellij defaults to $EDITOR/$VISUAL — but those
// captured `vim` when the zellij server first started (00-env.sh runs the
// `command -v nvim` check BEFORE 10-path.sh adds linuxbrew to PATH, so nvim
// wasn't visible yet and the script fell through to vim). Hard-wiring nvim
// here makes scrollback edits land in nvim with clipboard=unnamedplus, so
// `y` writes to wl-copy and Ctrl+V in Claude Code pastes correctly.
scrollback_editor "{{ if .isMacOS }}/opt/homebrew/bin/nvim{{ else }}/home/linuxbrew/.linuxbrew/bin/nvim{{ end }}"

show_startup_tips false
show_release_notes false
