# 20-tools.sh - Tools management (shared between bash and zsh)

# Detect current shell
if [ -n "$BASH_VERSION" ]; then
  CURRENT_SHELL="bash"
elif [ -n "$ZSH_VERSION" ]; then
  CURRENT_SHELL="zsh"
else
  CURRENT_SHELL="unknown"
fi

{{if not .remote -}}
# setup gpg-agent ssh
unset SSH_AGENT_PID
if [ "${gnupg_SSH_AUTH_SOCK_by:-0}" -ne $$ ]; then
  export SSH_AUTH_SOCK="$(gpgconf --list-dirs agent-ssh-socket)"
fi
{{- end}}

# Homebrew - enable if found
# macOS: Homebrew is typically at /usr/local/bin/brew or /opt/homebrew/bin/brew
# Linux: Homebrew is typically at /home/linuxbrew/.linuxbrew/bin/brew
if [ -f /usr/local/bin/brew ]; then
  eval "$(/usr/local/bin/brew shellenv)"
elif [ -f /opt/homebrew/bin/brew ]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [ -f /home/linuxbrew/.linuxbrew/bin/brew ]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# activate mise
if command -v mise >/dev/null; then
  eval "$(mise activate $CURRENT_SHELL)"
fi

# enable the starship prompt
if command -v starship >/dev/null; then
  eval "$(starship init $CURRENT_SHELL)"
fi

# fzf shell integration lives in 30-fzf.sh.tmpl (loaded right after this file)
# so FZF_DEFAULT_OPTS/COMMAND can be set in one focused place.

# --- Completions that use process substitution ---
# These all emit shell code via stdout (`<cmd> completion bash` etc.). On macOS
# bash 3.2 has known process-substitution bugs in subshells, so we gate them to
# Linux. Each one extends bash completion for that binary.
{{- if not .isMacOS }}
if [ "$CURRENT_SHELL" = "bash" ]; then
  command -v kubectl  >/dev/null && eval "$(kubectl completion bash)"
  command -v flux     >/dev/null && eval "$(flux completion bash)"
  command -v chezmoi  >/dev/null && eval "$(chezmoi completion bash)"
  command -v gh       >/dev/null && eval "$(gh completion -s bash)"
  command -v docker   >/dev/null && eval "$(docker completion bash 2>/dev/null)" || true
  command -v kind     >/dev/null && eval "$(kind completion bash)"
  command -v k9s      >/dev/null && eval "$(k9s completion bash)"
  command -v niri     >/dev/null && eval "$(niri completions bash 2>/dev/null)" || true
  command -v zellij   >/dev/null && eval "$(zellij setup --generate-completion bash 2>/dev/null)" || true
  # `claude` (the PAI CLI / Anthropic Claude Code binary) does NOT have a
  # completion subcommand. Running `claude completion bash` is interpreted as
  # a chat prompt and returns "Acknowledged. Standing by..." which then gets
  # eval'd as shell code, producing `bash: command not found: Acknowledged.`
  # Leave it out unless/until upstream adds real completion support.
fi
{{- end }}

# zoxide is initialized in ~/.bashrc (after this file + bash-completion + direnv
# + AsyncAPI) so its PROMPT_COMMAND hook isn't displaced. Do not init here.

# bat - better cat with syntax highlighting
if command -v bat >/dev/null; then
  if [ "$CURRENT_SHELL" = "bash" ]; then
    eval "$(bat --completion bash)"
  fi
  # zsh: bat completion is typically installed via package manager
fi

# chezmoi handled in the Linux completion block above.

# eza - modern ls replacement
if command -v eza >/dev/null; then
  if [ "$CURRENT_SHELL" = "bash" ]; then
    # eza bash completion is typically installed via package manager
    # or can be sourced from: https://github.com/eza-community/eza/blob/main/completions/bash/eza
    [[ -f /usr/share/bash-completion/completions/eza ]] && source /usr/share/bash-completion/completions/eza
  elif [ "$CURRENT_SHELL" = "zsh" ]; then
    # eza zsh completion is typically in fpath
    # or can be sourced from: https://github.com/eza-community/eza/blob/main/completions/zsh/_eza
    [[ -f /usr/share/zsh/site-functions/_eza ]] && source /usr/share/zsh/site-functions/_eza
  fi
fi

# yazi - terminal file manager
# Note: yazi doesn't have built-in completion generation
# Completions are typically installed via package manager or manually

# tmux - terminal multiplexer
# Note: tmux doesn't have built-in completion generation
# Completions are typically installed via package manager or manually

# uv - Python package installer
if command -v uv >/dev/null; then
  if [ "$CURRENT_SHELL" = "bash" ]; then
    eval "$(uv generate-shell-completion bash)"
  fi
  # zsh: uv completion is typically installed via package manager
fi

# npm - Node package manager (from node)
if command -v npm >/dev/null; then
  if [ "$CURRENT_SHELL" = "bash" ]; then
    eval "$(npm completion)"
  fi
  # zsh: npm completion is typically installed via package manager or use zsh-completions
fi

