# 90-zoxide.sh — zoxide init MUST run last
#
# zoxide hooks PROMPT_COMMAND to track directory changes. If another tool
# (starship, fabric, completions, AsyncAPI) appends to PROMPT_COMMAND after
# zoxide initializes, zoxide's hook can be displaced and it warns at every
# command. Keeping zoxide in its own high-numbered file ensures it runs after
# all other ~/.config/shell/*.sh fragments.
#
# (zoxide doctor still suggests "right at the end of your shell configuration
# file" — i.e. .bashrc itself. If the warning persists, move this init block
# into dot_bashrc.tmpl after the AsyncAPI line.)

if [ -n "$BASH_VERSION" ]; then
  _ZO_SHELL="bash"
elif [ -n "$ZSH_VERSION" ]; then
  _ZO_SHELL="zsh"
else
  _ZO_SHELL=""
fi

if [ -n "$_ZO_SHELL" ] && command -v zoxide >/dev/null; then
  # Strip completion block; uses process substitution incompatible with some macOS shells.
  eval "$(zoxide init "$_ZO_SHELL" | sed '/^# Load completions/,$d')"
fi
unset _ZO_SHELL
