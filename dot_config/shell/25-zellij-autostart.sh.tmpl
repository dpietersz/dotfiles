# 25-zellij-autostart.sh - Auto-attach to the "main" Zellij session in opted-in local GUI terminals.
# Wrappers (kitty-zellij, alacritty-zellij) set AUTO_START_ZELLIJ=1.
# `zellij attach -c main` creates the session if missing, attaches if present.

if command -v zellij >/dev/null 2>&1 && [[ $- == *i* ]] \
  && [[ -n "${AUTO_START_ZELLIJ:-}" ]] \
  && [[ -z "${NO_AUTO_ZELLIJ:-}" ]] \
  && [[ -z "${ZELLIJ:-}" ]] \
  && [[ -z "${SSH_CONNECTION:-}" ]]; then
  exec zellij attach -c main
fi
