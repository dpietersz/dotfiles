# 25-zellij-autostart.sh - Auto-start Zellij in opted-in local GUI terminals

if command -v zellij >/dev/null 2>&1 && [[ $- == *i* ]]; then
  if [[ -n "${AUTO_START_ZELLIJ:-}" ]] \
    && [[ -z "${NO_AUTO_ZELLIJ:-}" ]] \
    && [[ -z "${ZELLIJ:-}" ]] \
    && [[ -z "${SSH_CONNECTION:-}" ]]; then

    zellij_auto_mode="${ZELLIJ_AUTO_MODE:-new-or-main}"

    case "$zellij_auto_mode" in
      main)
        zellij attach -c main
        ;;
      new-or-main|*)
        if zellij list-sessions --short 2>/dev/null | grep -Fxq "main"; then
          zellij
        else
          zellij attach -c main
        fi
        ;;
    esac

    unset zellij_auto_mode
  fi
fi
