# Regular tools for all environments
[tools]
age = "latest"
bat = "latest"
{{- if not .isMacOS }}
btop = "latest"
{{- end }}
{{- if not .remote }}
android-sdk = "latest"  # Android SDK command-line tools (host only)
{{- end }}
bun = "latest"
chezmoi = "latest"
claude = "latest"
cloudflared = "latest"
direnv = "latest"
docker-compose = "latest"
doppler = "latest"
doggo = "latest"
eza = "latest"
fd = "latest"
fzf = "latest"
flux2 = "latest"
gemini = "latest"
go = "latest"
gitui = "latest"
gh = "latest"
gum = "latest"
{{- if not .remote }}
java = "temurin-17"     # Java 17 (Temurin), required by Android SDK tools (host only)
{{- end }}
k9s = "latest"
kubectl = "latest"
kubeseal = "latest"
lazydocker = "latest"
lazygit = "latest"
{{- if not .isMacOS }}
navi = "latest"
{{- end }}
neovim = "0.11.4"
node = "22.21.0"
"github:sst/opencode" = "latest"
python = "3.12.12"
ripgrep = "latest"
starship = "1.23.0"
swag = "latest"
terraform = "latest"
uv = "latest"
yazi = "latest"
{{- if not .remote }}
yq = "latest"           # YAML processor, required by mise android-sdk plugin (host only)
{{- end }}
zellij = "latest"
zoxide = "latest"
