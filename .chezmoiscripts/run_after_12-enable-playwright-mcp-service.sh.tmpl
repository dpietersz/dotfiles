#!/bin/bash
{{- if or .remote .isServer }}
# Skip on remote or headless server (no browser GUI, no distrobox).
exit 0
{{- end }}

set -euo pipefail

# ------------------ Setup Playwright MCP ------------------
# This script sets up Playwright for use with OpenCode MCP.
#
# On Linux (Bluefin/Fedora):
#   1. Creates playwright distrobox from ghcr.io/dpietersz/playwright-toolbox
#   2. Exports playwright CLI tools to host via distrobox-export
#   3. Installs/updates browsers inside the container
#   4. Starts the MCP server via systemd
#
# On macOS:
#   1. Installs Playwright browsers natively via bunx
#   2. Starts the Bun-global Playwright MCP server via launchd
#
# On remote: Skips entirely

{{- if .remote }}
echo "[playwright] Skipping: remote environment (.remote=true)."
exit 0
{{- end }}

{{- if .isMacOS }}
# ------------------ macOS: Native installation ------------------
echo "[playwright] macOS detected, using native installation..."

# Check if bunx is available
if ! command -v bunx >/dev/null 2>&1; then
  [ -x "$HOME/.bun/bin/bunx" ] && export PATH="$HOME/.bun/bin:$PATH"
fi
if ! command -v bunx >/dev/null 2>&1; then
  echo "[playwright] bunx not found, skipping. Earlier Bun install scripts should provide it."
  exit 0
fi

# Install Playwright browsers if not already installed
if [ ! -d "$HOME/Library/Caches/ms-playwright" ]; then
  echo "[playwright] Installing Playwright browsers..."
  bunx --package @playwright/test playwright install chromium
fi

PLAYWRIGHT_MCP_PATH="$HOME/.bun/bin/playwright-mcp"
if [ ! -x "$PLAYWRIGHT_MCP_PATH" ]; then
  echo "[playwright] $PLAYWRIGHT_MCP_PATH not found, skipping. run_onchange_after_02a-install-bun-globals should install @playwright/mcp."
  exit 0
fi
echo "[playwright] Using Playwright MCP at: $PLAYWRIGHT_MCP_PATH"

# Create launchd plist for playwright-mcp
PLIST_FILE="$HOME/Library/LaunchAgents/com.playwright.mcp.plist"
mkdir -p "$HOME/Library/LaunchAgents"

cat > "$PLIST_FILE" << EOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.playwright.mcp</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>$HOME/.local/share/mise/shims:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>
    <key>ProgramArguments</key>
    <array>
        <string>$PLAYWRIGHT_MCP_PATH</string>
        <string>--headless</string>
        <string>--browser</string>
        <string>chromium</string>
        <string>--port</string>
        <string>8931</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/tmp/playwright-mcp.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/playwright-mcp.err</string>
</dict>
</plist>
EOF

# Load the launchd service
launchctl unload "$PLIST_FILE" 2>/dev/null || true
launchctl load "$PLIST_FILE"

echo "[playwright] launchd service loaded."
sleep 3

# Verify the service is listening
if lsof -i :8931 >/dev/null 2>&1; then
  echo "[playwright] ✅ Playwright MCP is listening on http://localhost:8931/mcp"
else
  echo "[playwright] ⚠️  Warning: Service may not be listening. Check /tmp/playwright-mcp.log"
fi

exit 0
{{- end }}

# ------------------ Linux: Distrobox-based installation ------------------

# Only proceed if distrobox is installed
if ! command -v distrobox >/dev/null 2>&1; then
  echo "[playwright] distrobox not installed, skipping."
  exit 0
fi

PLAYWRIGHT_BOX="playwright"
PLAYWRIGHT_IMAGE="ghcr.io/dpietersz/playwright-toolbox:latest"
DISTROBOX_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/distrobox"
PLAYWRIGHT_INI="$DISTROBOX_CONFIG_DIR/playwright-toolbox.ini"
PLAYWRIGHT_RECREATED=0

box_exists() {
  distrobox list --no-color 2>/dev/null \
    | awk -F'|' -v box="$PLAYWRIGHT_BOX" 'NR > 1 { gsub(/^[[:space:]]+|[[:space:]]+$/, "", $2); if ($2 == box) found=1 } END { exit found ? 0 : 1 }'
}

# Fetch only the remote manifest digest. If remote/local digests differ, recreate
# the container so weekly :latest image rebuilds actually land on the host.
image_is_stale() {
  local remote_digest local_digest container_image local_image_id

  if ! command -v skopeo >/dev/null 2>&1 || ! command -v podman >/dev/null 2>&1; then
    echo "[playwright] skopeo/podman not available; skipping stale-image check."
    return 1
  fi

  remote_digest=$(skopeo inspect --no-tags --format '{{`{{.Digest}}`}}' "docker://$PLAYWRIGHT_IMAGE" 2>/dev/null || true)
  [ -z "$remote_digest" ] && return 1

  local_digest=$(podman image inspect "$PLAYWRIGHT_IMAGE" --format '{{`{{.Digest}}`}}' 2>/dev/null || true)
  if [ -z "$local_digest" ] || [ "$remote_digest" != "$local_digest" ]; then
    return 0
  fi

  container_image=$(podman container inspect "$PLAYWRIGHT_BOX" --format '{{`{{.Image}}`}}' 2>/dev/null || true)
  local_image_id=$(podman image inspect "$PLAYWRIGHT_IMAGE" --format '{{`{{.Id}}`}}' 2>/dev/null || true)
  [ -n "$container_image" ] && [ -n "$local_image_id" ] && [ "$container_image" != "$local_image_id" ]
}

create_playwright_box() {
  if [ ! -f "$PLAYWRIGHT_INI" ]; then
    echo "[playwright] playwright-toolbox.ini not found, skipping."
    exit 0
  fi

  distrobox-assemble create --file "$PLAYWRIGHT_INI"
  PLAYWRIGHT_RECREATED=1
  echo "[playwright] Distrobox created."
}

if box_exists; then
  if image_is_stale; then
    echo "[playwright] image is stale -> stopping and recreating distrobox"
    systemctl --user stop playwright-mcp.service 2>/dev/null || true
    distrobox stop -Y "$PLAYWRIGHT_BOX" </dev/null >/dev/null 2>&1 || true
    distrobox rm -f "$PLAYWRIGHT_BOX" </dev/null >/dev/null 2>&1 || true
    create_playwright_box
  else
    echo "[playwright] distrobox exists and image is current."
  fi
else
  echo "[playwright] Creating playwright distrobox..."
  create_playwright_box
fi

# Export Playwright CLI tools to host (this is the distrobox way!)
# This makes playwright, playwright-test, playwright-codegen available on the host
echo "[playwright] Exporting Playwright CLI tools to host..."
if [ "$PLAYWRIGHT_RECREATED" = 1 ] || [ ! -f "$HOME/.local/bin/playwright" ]; then
  distrobox enter "$PLAYWRIGHT_BOX" -- /usr/local/bin/setup-host-integration
  echo "[playwright] CLI tools exported to ~/.local/bin/"
else
  echo "[playwright] CLI tools already exported."
fi

# Ensure browsers are installed and up-to-date
echo "[playwright] Ensuring browsers are installed..."
distrobox enter "$PLAYWRIGHT_BOX" -- bash -c '
  export PLAYWRIGHT_BROWSERS_PATH=/opt/playwright-browsers
  
  # Fix permissions for browser profiles
  sudo chmod -R 777 /opt/playwright-browsers 2>/dev/null || true
  
  # Install chromium using Bun npx replacement. Home is mounted into the container.
  "$HOME/.bun/bin/bun" x --package @playwright/test playwright install chromium 2>&1 || true
'
echo "[playwright] Browsers ready."

# Start the MCP server via systemd
SERVICE_FILE="$HOME/.config/systemd/user/playwright-mcp.service"
if [ ! -f "$SERVICE_FILE" ]; then
  echo "[playwright] Service file not found at $SERVICE_FILE, skipping MCP setup."
  echo "[playwright] ✅ Playwright CLI tools are available on host. Use: playwright --help"
  exit 0
fi

echo "[playwright] Starting MCP server..."
systemctl --user daemon-reload
systemctl --user enable playwright-mcp.service

# Stop any existing instance on port 8931
if lsof -i :8931 >/dev/null 2>&1; then
  echo "[playwright] Stopping existing process on port 8931..."
  lsof -ti :8931 | xargs kill -9 2>/dev/null || true
  sleep 2
fi

# Start the service
if ! systemctl --user is-active --quiet playwright-mcp.service; then
  systemctl --user start playwright-mcp.service
  sleep 3
fi

# Verify
if lsof -i :8931 >/dev/null 2>&1; then
  echo "[playwright] ✅ MCP server listening on http://localhost:8931/mcp"
else
  echo "[playwright] ⚠️  MCP server may not be ready. Check: journalctl --user -u playwright-mcp -n 20"
fi

echo "[playwright] ✅ Setup complete!"
echo "[playwright]    - CLI tools: playwright, playwright-test, playwright-codegen"
echo "[playwright]    - MCP server: http://localhost:8931/mcp"
