#!/bin/bash
{{- if .remote }}
exit 0
{{- end }}

set -euo pipefail

# Configures gpg-agent's pinentry-program. Renamed from run_once_* to
# run_onchange_* on 2026-05-26 because the previous version exited early on
# Linux desktop, leaving gpg-agent.conf without a pinentry-program line. That
# race-condition'd gnome-keyring vs gpg-agent at login and surfaced as a
# double pinentry popup. Running on every change means tightening the binary
# preference order doesn't require manual state resets.

echo "🔐 Configuring GPG pinentry..."

# Create GPG config directory if it doesn't exist
mkdir -p "$HOME/.gnupg"
chmod 700 "$HOME/.gnupg"

# Configure GPG to use terminal-based pinentry
GPG_AGENT_CONF="$HOME/.gnupg/gpg-agent.conf"

{{- if .isServer }}
# Headless server: pinentry-curses needs a min terminal size and breaks on
# narrow SSH sessions. Use pinentry-tty (plain readline prompt) instead.
if ! command -v pinentry-tty >/dev/null 2>&1; then
  echo "Installing pinentry-tty via apt..."
  sudo apt-get install -y pinentry-tty
fi
PINENTRY_PATH="$(command -v pinentry-tty)"
{{- else if .isMacOS }}
# macOS: use pinentry-tty so SSH'd-in sessions can enter the GPG passphrase
# right in the terminal (no GUI dialog needing to pop on the local console,
# no pinentry-curses "Screen or window too small" issue). Brew's `pinentry`
# package ships pinentry-tty alongside pinentry-curses + pinentry — same
# install, just different binary.
if ! command -v pinentry-tty >/dev/null 2>&1; then
  echo "Installing pinentry via brew (provides pinentry-tty)..."
  brew install pinentry
fi
PINENTRY_PATH="$(command -v pinentry-tty)"
{{- else }}
# Linux desktop (Bluefin / Bazzite / generic Fedora) — niri + Wayland.
# Prefer pinentry-gnome3 explicitly so we get a graphical prompt under the
# Wayland compositor. `/usr/bin/pinentry` (alternatives-wrapper) can resolve
# to pinentry-curses on Bluefin, which then fails silently when gpg-agent is
# called from a non-tty context (vibe-typer, ssh-add via niri spawn, etc.) —
# that's what produced the double-prompt regression.
if command -v pinentry-gnome3 >/dev/null 2>&1; then
  PINENTRY_PATH="$(command -v pinentry-gnome3)"
elif command -v pinentry-gtk-2 >/dev/null 2>&1; then
  PINENTRY_PATH="$(command -v pinentry-gtk-2)"
elif command -v pinentry-qt >/dev/null 2>&1; then
  PINENTRY_PATH="$(command -v pinentry-qt)"
elif command -v pinentry >/dev/null 2>&1; then
  PINENTRY_PATH="$(command -v pinentry)"
else
  echo "❌ Error: no pinentry binary found"
  exit 1
fi
{{- end }}

# Kill any running gpg-agent to clear old configuration
echo "Stopping gpg-agent to clear old configuration..."
gpg-connect-agent killagent /bye &>/dev/null || true
sleep 1

# Update or create gpg-agent.conf with pinentry
if [ -f "$GPG_AGENT_CONF" ]; then
  # Remove existing pinentry-program line. macOS sed needs '' after -i;
  # GNU sed (Linux) does not. Detect once.
  if sed --version >/dev/null 2>&1; then
    sed -i '/^pinentry-program/d' "$GPG_AGENT_CONF"
  else
    sed -i '' '/^pinentry-program/d' "$GPG_AGENT_CONF"
  fi
else
  # Create new config file
  touch "$GPG_AGENT_CONF"
fi

# Add pinentry configuration
echo "pinentry-program $PINENTRY_PATH" >> "$GPG_AGENT_CONF"

# Add cache settings for better UX
if ! grep -q "^default-cache-ttl" "$GPG_AGENT_CONF"; then
  echo "default-cache-ttl 3600" >> "$GPG_AGENT_CONF"
fi

if ! grep -q "^max-cache-ttl" "$GPG_AGENT_CONF"; then
  echo "max-cache-ttl 7200" >> "$GPG_AGENT_CONF"
fi

# Ensure proper permissions
chmod 600 "$GPG_AGENT_CONF"

# Reload gpg-agent to apply changes
echo "Reloading gpg-agent with new configuration..."
gpg-connect-agent reloadagent /bye &>/dev/null || true

echo "✅ GPG configured to use terminal-based pinentry"
echo "   Pinentry program: $PINENTRY_PATH"
echo "   Config file: $GPG_AGENT_CONF"
