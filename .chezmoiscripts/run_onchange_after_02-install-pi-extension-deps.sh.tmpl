#!/bin/bash
# minion-subagents deps: {{ include "dot_pi/agent/extensions/minion-subagents/package.json" | sha256sum }}

set -euo pipefail

echo "[pi-extensions] Installing dependencies for minion-subagents (via bun)..."

EXT_DIR="{{ .chezmoi.homeDir }}/.pi/agent/extensions/minion-subagents"

if [ ! -d "$EXT_DIR" ]; then
  echo "[pi-extensions] Extension directory not found, skipping"
  exit 0
fi

# bun may live in ~/.bun/bin (pai-deps installer) or in brew. chezmoi's
# subshell doesn't inherit user shell rc, so PATH may not include either.
if ! command -v bun >/dev/null 2>&1; then
  [ -x "$HOME/.bun/bin/bun" ] && export PATH="$HOME/.bun/bin:$PATH"
fi
if ! command -v bun >/dev/null 2>&1; then
  for cand in /home/linuxbrew/.linuxbrew/bin/brew /opt/homebrew/bin/brew; do
    [ -x "$cand" ] && eval "$("$cand" shellenv bash)" && break
  done
fi
if ! command -v bun >/dev/null 2>&1; then
  echo "[pi-extensions] bun not found on PATH, ~/.bun/bin, or brew prefix — skipping"
  exit 0
fi

cd "$EXT_DIR"
bun install
echo "[pi-extensions] Done"
