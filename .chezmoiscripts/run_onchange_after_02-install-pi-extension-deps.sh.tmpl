#!/bin/bash
# minion-subagents deps: {{ include "dot_pi/agent/extensions/minion-subagents/package.json" | sha256sum }}

set -euo pipefail

echo "[pi-extensions] Installing dependencies for minion-subagents (via bun)..."

EXT_DIR="{{ .chezmoi.homeDir }}/.pi/agent/extensions/minion-subagents"

if [ ! -d "$EXT_DIR" ]; then
  echo "[pi-extensions] Extension directory not found, skipping"
  exit 0
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "[pi-extensions] bun not found; ensure Brewfile.tmpl has installed it"
  exit 1
fi

cd "$EXT_DIR"
bun install
echo "[pi-extensions] Done"
