#!/bin/bash
set -euo pipefail

{{- if or .remote .isMacOS }}
echo "[pai-pulse] Skipping: macOS uses launchd (PAI/PULSE/manage.sh install)."
exit 0
{{- end }}

# Bluefin/Fedora path — systemd user service
SERVICE_FILE="$HOME/.config/systemd/user/pai-pulse.service"
if [ ! -f "$SERVICE_FILE" ]; then
    echo "[pai-pulse] Service file not found at $SERVICE_FILE — chezmoi may not have applied yet"
    exit 1
fi

if [ ! -x "$HOME/.bun/bin/bun" ]; then
    echo "[pai-pulse] bun not found at \$HOME/.bun/bin/bun — earlier install script should have set this up"
    exit 1
fi

if [ ! -d "$HOME/.claude/PAI/PULSE" ]; then
    echo "[pai-pulse] PAI/PULSE not synced yet — set up Syncthing share for ~/.claude first, then re-run"
    exit 0  # not an error, just not ready yet
fi

echo "[pai-pulse] Enabling lingering (so the daemon runs without an active login)…"
sudo loginctl enable-linger "$USER"

echo "[pai-pulse] Reloading user systemd daemon…"
systemctl --user daemon-reload

echo "[pai-pulse] Enabling pai-pulse.service…"
systemctl --user enable pai-pulse.service

if ! systemctl --user is-active --quiet pai-pulse.service; then
    systemctl --user start pai-pulse.service
    echo "[pai-pulse] Started."
else
    systemctl --user restart pai-pulse.service
    echo "[pai-pulse] Restarted (was already running)."
fi

echo ""
echo "🌐 Voice/notify endpoint: http://localhost:31337/notify"
echo "   Smoke test:"
echo "   curl -s -X POST http://localhost:31337/notify \\"
echo "     -H 'Content-Type: application/json' \\"
echo "     -d '{\"message\":\"Pulse online from Linux\",\"voice_enabled\":true}'"
echo ""
echo "   Logs:  journalctl --user -u pai-pulse -f"
echo ""
