#!/bin/bash
{{- if .remote }}
# Skip on remote environments
exit 0
{{- end }}

# pi-coding-agent installation hash: {{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}

set -euo pipefail

# Check if npm is available
if ! command -v npm >/dev/null 2>&1; then
  echo "[pi-coding-agent] npm not found, skipping installation"
  exit 0
fi

# Check if pi is already installed
if command -v pi >/dev/null 2>&1; then
  echo "[pi-coding-agent] already installed, skipping"
  exit 0
fi

{{- if .isMacOS }}
# macOS: Install globally via npm
echo "[pi-coding-agent] Installing globally..."
npm install -g @mariozechner/pi-coding-agent@latest
echo "[pi-coding-agent] ✓ Installation successful"

{{- else }}
# Linux: Install to persistent user directory (works on Bluefin/atomic systems)
# - Uses ~/.local/share/npm instead of /usr/local (which is immutable on Bluefin)
# - ~/.local/share/npm/bin is in PATH (configured in dot_config/shell/10-path.sh.tmpl)
echo "[pi-coding-agent] Installing to ~/.local/share/npm..."
npm install --prefix "$HOME/.local/share/npm" --no-save --ignore-scripts @mariozechner/pi-coding-agent@latest

# Create symlink from bin to node_modules/.bin for PATH compatibility
NPM_BIN_DIR="$HOME/.local/share/npm/bin"
NPM_NODE_MODULES_BIN="$HOME/.local/share/npm/node_modules/.bin"

if [[ -d "$NPM_NODE_MODULES_BIN" ]]; then
  mkdir -p "$NPM_BIN_DIR"
  ln -sf "$NPM_NODE_MODULES_BIN" "$NPM_BIN_DIR" 2>/dev/null || true
  echo "[pi-coding-agent] ✓ Installation successful: $NPM_BIN_DIR/pi"
else
  echo "[pi-coding-agent] ✗ Installation failed: node_modules/.bin not found"
  exit 1
fi

{{- end }}
