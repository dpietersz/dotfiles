#!/bin/bash
# Runs on every `chezmoi apply` because remote image bumps at ghcr.io are
# invisible to chezmoi's content-hash gating. The internal skopeo manifest
# checks are cheap (~1s per box) so the per-apply overhead is small.

{{- if .remote }}
echo "Skipping toolbox creation on remote system"
exit 0
{{- else }}
{{- if not (or .isBluefin .isFedora) }}
echo "Skipping toolbox creation (only runs on Bluefin/Fedora)"
exit 0
{{- else }}

set -euo pipefail

if ! command -v distrobox-assemble >/dev/null 2>&1; then
  echo "[toolboxes] distrobox not available; skipping (will retry on next apply)"
  exit 0
fi

DISTROBOX_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/distrobox"
EXPORT_SCRIPT="$HOME/.local/bin/scripts/distrobox-auto-export.sh"
HASH_DIR="$HOME/.cache/dotfiles/toolbox-export-hashes"
mkdir -p "$HASH_DIR"

# Playwright is intentionally owned by run_after_12-enable-playwright-mcp-service,
# which has its own service restart + CLI export flow.
SKIP_INIS=("playwright-toolbox.ini")

# Parse a key from a .ini file (returns first match, no section awareness needed
# because each ini has a single section).
ini_get() {
  local file="$1" key="$2"
  awk -F= -v k="$key" '
    $1 ~ ("^[[:space:]]*" k "[[:space:]]*$") {
      sub(/^[[:space:]]+/, "", $2); sub(/[[:space:]]+$/, "", $2); print $2; exit
    }
  ' "$file"
}

# Container name lives as either `container_name=` or `name=` in distrobox .ini files.
ini_container_name() {
  local file="$1" name
  name="$(ini_get "$file" "container_name")"
  [ -z "$name" ] && name="$(ini_get "$file" "name")"
  echo "$name"
}

box_exists() {
  distrobox list 2>/dev/null \
    | awk -F'|' '{gsub(/ /,"",$2); print $2}' \
    | grep -qx "$1"
}

# Staleness check via skopeo: fetches only the manifest (~1.5KB) instead of
# the full image blobs. Returns 0 (stale) when we should recreate.
image_is_stale() {
  local box="$1" image="$2"
  local remote_digest local_digest container_image local_image_id
  remote_digest=$(skopeo inspect --no-tags --format '{{`{{.Digest}}`}}' "docker://$image" 2>/dev/null || true)
  [ -z "$remote_digest" ] && return 1  # can't tell remote; don't churn
  local_digest=$(podman image inspect "$image" --format '{{`{{.Digest}}`}}' 2>/dev/null || true)
  if [ -z "$local_digest" ] || [ "$remote_digest" != "$local_digest" ]; then
    return 0  # remote newer (or image not pulled locally)
  fi
  container_image=$(podman container inspect "$box" --format '{{`{{.Image}}`}}' 2>/dev/null || true)
  local_image_id=$(podman image inspect "$image" --format '{{`{{.Id}}`}}' 2>/dev/null || true)
  [ -n "$container_image" ] && [ -n "$local_image_id" ] && [ "$container_image" != "$local_image_id" ]
}

run_exports_in_box() {
  local box="$1"
  [ -x "$EXPORT_SCRIPT" ] || { echo "[toolboxes] WARN: export script missing or not executable: $EXPORT_SCRIPT"; return 1; }
  echo "[toolboxes] running export script inside $box"
  distrobox enter "$box" -- bash "$EXPORT_SCRIPT" 2>&1 | sed 's/^/  /'
}

refresh_exports_if_changed() {
  local box="$1"
  local hash_file="$HASH_DIR/$box.sha256"
  local current previous

  [ -x "$EXPORT_SCRIPT" ] || return 0

  current=$(sha256sum "$EXPORT_SCRIPT" | cut -d' ' -f1)
  previous=$(cat "$hash_file" 2>/dev/null || true)

  if [ "$current" = "$previous" ]; then
    return 0
  fi

  echo "[toolboxes] export script changed for $box -> refreshing"
  if run_exports_in_box "$box"; then
    echo "$current" > "$hash_file"
  else
    echo "[toolboxes] WARN: refresh failed for $box; will retry on next apply"
  fi
}

# Auto-discover every .ini in the config dir; future toolboxes drop their .ini
# and require zero changes to this script.
shopt -s nullglob
for ini in "$DISTROBOX_CONFIG_DIR"/*.ini; do
  ini_filename="$(basename "$ini")"

  skip=0
  for s in "${SKIP_INIS[@]}"; do
    [ "$ini_filename" = "$s" ] && skip=1 && break
  done
  if [ "$skip" = 1 ]; then
    echo "[toolboxes] $ini_filename has its own pipeline; skipping here"
    continue
  fi

  box="$(ini_container_name "$ini")"
  image="$(ini_get "$ini" "image")"

  if [ -z "$box" ] || [ -z "$image" ]; then
    echo "[toolboxes] WARN: could not parse name/image from $ini_filename; skipping"
    continue
  fi

  if box_exists "$box"; then
    if image_is_stale "$box" "$image"; then
      echo "[toolboxes] $box image is stale -> stopping and recreating"
      echo "  (in-container state will be lost; \$HOME is mounted from host so files are safe)"
      # -Y skips the y/n confirmation that newer distrobox versions added on
      # stop. Output redirection silences the prompt but stdin still reads
      # from the terminal, causing chezmoi apply to hang invisibly.
      # </dev/null is belt-and-suspenders if a future flag changes again.
      distrobox stop -Y "$box" </dev/null >/dev/null 2>&1 || true
      distrobox rm -f "$box" </dev/null >/dev/null 2>&1 || true
      distrobox-assemble create --file "$ini"
      # init_hooks declared in .ini only fires on first `distrobox enter`, not
      # on `distrobox-assemble create`. Invoke exports explicitly so a fresh
      # box ends up with apps on host even if user never enters it manually.
      run_exports_in_box "$box" || true
      [ -x "$EXPORT_SCRIPT" ] && sha256sum "$EXPORT_SCRIPT" | cut -d' ' -f1 > "$HASH_DIR/$box.sha256"
    else
      echo "[toolboxes] $box exists and image is current"
      refresh_exports_if_changed "$box"
    fi
  else
    echo "[toolboxes] $box missing -> creating from $ini_filename"
    distrobox-assemble create --file "$ini"
    run_exports_in_box "$box" || true
    # Fresh container creation is flaky: init_hooks + the first explicit
    # export call can race with the host home mount stabilizing, leading to
    # some icons silently failing to copy (observed: only ferdium landed on
    # first run; rerunning afterwards copied the rest). Sleep + second pass
    # is cheap because the export script uses cp -n (no-clobber).
    sleep 2
    run_exports_in_box "$box" || true
    # Refresh the host icon cache from outside the container too — inside
    # the container we already do this, but doing it host-side ensures any
    # icons newly landed by the second pass become visible immediately.
    if command -v gtk-update-icon-cache >/dev/null 2>&1; then
      gtk-update-icon-cache -t -q "$HOME/.local/share/icons/hicolor" 2>/dev/null || true
    fi
    [ -x "$EXPORT_SCRIPT" ] && sha256sum "$EXPORT_SCRIPT" | cut -d' ' -f1 > "$HASH_DIR/$box.sha256"
  fi
done

echo "[toolboxes] done"
distrobox list

{{- end }}
{{- end }}
