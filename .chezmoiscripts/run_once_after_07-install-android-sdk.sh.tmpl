#!/bin/bash

{{- if .remote }}
exit 0
{{- end }}

set -euo pipefail

# ------------------ Android SDK Install ------------------
# Installs Android SDK command-line tools and base packages.
# Runs ONCE after mise has installed java, yq, and android-sdk.
#
# - macOS:  installs via Homebrew casks (android-commandlinetools, android-platform-tools)
# - Linux:  downloads cmdline-tools zip from Google if sdkmanager not already on PATH
# - Skips on remote environments (containers/devpods)
#
# Packages installed: platform-tools, platforms;android-35, build-tools;35.0.0, emulator

{{- if .isMacOS }}

# ------------------ macOS ------------------

if command -v sdkmanager >/dev/null 2>&1; then
  echo "[android-sdk] sdkmanager already available, skipping install"
  exit 0
fi

echo "[android-sdk] Installing Android command-line tools via Homebrew..."
brew install --cask android-commandlinetools
brew install --cask android-platform-tools

ANDROID_SDK_ROOT="$(brew --prefix)/share/android-commandlinetools"

# Create repositories.cfg to suppress sdkmanager warning
if [ ! -f "$HOME/.android/repositories.cfg" ]; then
  echo "[android-sdk] Creating ~/.android/repositories.cfg..."
  mkdir -p "$HOME/.android"
  touch "$HOME/.android/repositories.cfg"
fi

echo "[android-sdk] Accepting licenses..."
yes | sdkmanager --sdk_root="$ANDROID_SDK_ROOT" --licenses

echo "[android-sdk] Installing SDK packages..."
sdkmanager --sdk_root="$ANDROID_SDK_ROOT" \
  "platform-tools" \
  "platforms;android-35" \
  "build-tools;35.0.0" \
  "emulator"

echo "[android-sdk] ✓ Android SDK installed at: $ANDROID_SDK_ROOT"

{{- else if or .isBluefin .isFedora }}

# ------------------ Linux (Bluefin / Fedora) ------------------

ANDROID_SDK_ROOT="$HOME/.local/share/android-sdk"
SDKMANAGER_BIN="$ANDROID_SDK_ROOT/cmdline-tools/latest/bin/sdkmanager"

# If sdkmanager is already on PATH (e.g. installed by mise android-sdk plugin), use it directly
if command -v sdkmanager >/dev/null 2>&1; then
  echo "[android-sdk] sdkmanager already on PATH, skipping download"
  SDKMANAGER_BIN="$(command -v sdkmanager)"
elif [ -x "$SDKMANAGER_BIN" ]; then
  echo "[android-sdk] sdkmanager already installed at $SDKMANAGER_BIN, skipping download"
else
  # Verify java is available (installed by mise)
  if ! command -v java >/dev/null 2>&1; then
    echo "[android-sdk] WARNING: java not found on PATH. Ensure mise has installed java before running this script."
    exit 1
  fi

  echo "[android-sdk] Downloading Android cmdline-tools..."
  CMDLINE_TOOLS_URL="https://dl.google.com/android/repository/commandlinetools-linux-14742923_latest.zip"
  tmp="$(mktemp -d)"

  curl -fsSL -o "$tmp/cmdline-tools.zip" "$CMDLINE_TOOLS_URL"

  echo "[android-sdk] Installing cmdline-tools to $ANDROID_SDK_ROOT..."
  mkdir -p "$ANDROID_SDK_ROOT/cmdline-tools"
  unzip -q "$tmp/cmdline-tools.zip" -d "$tmp"
  mkdir -p "$ANDROID_SDK_ROOT/cmdline-tools/latest"
  mv "$tmp/cmdline-tools/"* "$ANDROID_SDK_ROOT/cmdline-tools/latest/"
  rm -rf "$tmp"

  echo "[android-sdk] ✓ cmdline-tools installed"
fi

# Add cmdline-tools bin to PATH for the rest of this script
export PATH="$ANDROID_SDK_ROOT/cmdline-tools/latest/bin:$PATH"

# Create repositories.cfg to suppress sdkmanager warning
if [ ! -f "$HOME/.android/repositories.cfg" ]; then
  echo "[android-sdk] Creating ~/.android/repositories.cfg..."
  mkdir -p "$HOME/.android"
  touch "$HOME/.android/repositories.cfg"
fi

echo "[android-sdk] Accepting licenses..."
yes | sdkmanager --sdk_root="$ANDROID_SDK_ROOT" --licenses

echo "[android-sdk] Installing SDK packages..."
sdkmanager --sdk_root="$ANDROID_SDK_ROOT" \
  "platform-tools" \
  "platforms;android-35" \
  "build-tools;35.0.0" \
  "emulator"

echo "[android-sdk] ✓ Android SDK installed at: $ANDROID_SDK_ROOT"

{{- else }}

echo "[android-sdk] Skipping: unsupported OS (not macOS, Bluefin, or Fedora)"

{{- end }}
