#!/bin/bash
{{- if or .remote (not .isBluefin) }}
exit 0
{{- end }}

set -euo pipefail

# ------------------ Install voquill voice dictation ------------------
# Docs: https://docs.voquill.com/getting-started/linux
# Replaces the previous voxd setup. Niri keybinding lives in
# dot_config/niri/config.kdl.tmpl (F12).

REPO_FILE=/etc/yum.repos.d/voquill.repo
if [ ! -f "$REPO_FILE" ]; then
    echo "[voquill] Adding voquill rpm repo..."
    sudo tee "$REPO_FILE" >/dev/null <<'EOF'
[voquill-stable]
name=Voquill Desktop (stable)
baseurl=https://voquill.github.io/rpm/packages/stable
enabled=1
gpgcheck=1
gpgkey=https://voquill.github.io/rpm/gpg-key.asc
EOF
fi

# voquill-desktop + Wayland helpers ydotool (paste) and wtype (fallback)
need_install=()
for pkg in voquill-desktop ydotool wtype; do
    rpm -q "$pkg" >/dev/null 2>&1 || need_install+=("$pkg")
done

if [ ${#need_install[@]} -gt 0 ]; then
    echo "[voquill] Installing via rpm-ostree --apply-live: ${need_install[*]}"
    if ! sudo rpm-ostree install --apply-live --allow-inactive -y "${need_install[@]}"; then
        echo "[voquill] --apply-live failed; package(s) will be present after next reboot."
        exit 1
    fi
fi

# Grant /dev/uinput access for ydotool keystroke injection.
UINPUT_RULE=/etc/udev/rules.d/99-uinput.rules
if [ ! -f "$UINPUT_RULE" ]; then
    echo "[voquill] Installing udev rule for /dev/uinput..."
    echo 'KERNEL=="uinput", GROUP="input", MODE="0660"' | sudo tee "$UINPUT_RULE" >/dev/null
    sudo udevadm control --reload-rules
    sudo udevadm trigger
fi

# Add user to the input group so the udev rule actually grants access.
if ! id -nG "$USER" | tr ' ' '\n' | grep -qx input; then
    echo "[voquill] Adding $USER to input group (log out and back in to apply)..."
    sudo usermod -aG input "$USER"
    echo ""
    echo "⚠️  Log out and back in for input-group membership to take effect."
    echo ""
fi

echo "[voquill] Install complete. Niri keybinding: F12 (toggle dictation)."
echo "          Run 'voquill-desktop --help' to confirm the exact CLI flags."
