#!/bin/bash
# Settings revision: 2  -- bump to force re-apply when the DESIRED block changes.

set -euo pipefail

# ------------------ Vibe Typer authoritative settings ------------------
# Vibe Typer writes ~/.config/vibe-typer/config.json. Some keys are per-machine
# state (recentTargets, lastSignInEmail, userName, lastSeenReleaseNotesVersion,
# sync.updatedAt) — those we leave alone. The block below is the cross-machine
# source of truth. It's deep-merged into the existing config so per-machine keys
# survive but every key we declare here is overwritten on each chezmoi apply.
#
# To add words to the personal dictionary, edit dictionary.entries below and
# `chezmoi apply` — both Thinkpads get them.
#
# automaticUpdatesEnabled is FALSE on purpose: chezmoi polls cdn.vibetyper.com/
# releases/latest.json on every apply (see run_after_14-install-vibe-typer.sh.
# tmpl) and re-downloads the AppImage when a new version ships. Vibe Typer's
# built-in updater would race with that and clobber our managed install.

{{- if or .remote .isMacOS }}
exit 0
{{- end }}

CONFIG="$HOME/.config/vibe-typer/config.json"
[ -f "$CONFIG" ] || { echo "[vibe-typer-config] config not yet created (run app once); skipping."; exit 0; }
command -v jq >/dev/null 2>&1 || { echo "[vibe-typer-config] jq not installed; skipping."; exit 0; }

DESIRED=$(cat <<'JSON'
{
  "user": {
    "language": "auto",
    "muteSystemAudioDuringRecording": true,
    "hotkey": "CommandOrControl+Space",
    "toggleRecordingHotkey": true,
    "cancelTranscriptionHotkey": "Escape",
    "repasteTranscriptionHotkey": "F8",
    "launchAtStartup": true,
    "releaseChannel": "stable",
    "automaticUpdatesEnabled": false,
    "aiCommandModesEnabled": true,
    "disableLocalTranscriptionHistory": false,
    "realtimeTranscription": {
      "enabled": true,
      "autoFormatterEnabled": true
    },
    "dictionary": {
      "entries": [],
      "version": 1
    },
    "indicator": {
      "waveformGradient": {
        "color1Enabled": true,
        "color1": "#7c3aed",
        "color2Enabled": true,
        "color2": "#e9d8fd"
      }
    },
    "textInsertion": {
      "paste": {
        "modeMap": {
          "wayland-generic": "type"
        }
      },
      "tonePreset": "formal"
    }
  }
}
JSON
)

# Short-circuit if the file already contains every desired key with the desired
# value. jq's `*` (deep merge) followed by a diff against the original tells us
# whether anything would change.
merged=$(jq --argjson d "$DESIRED" '. * $d' "$CONFIG")
if [ "$merged" = "$(cat "$CONFIG")" ]; then
    exit 0
fi

echo "[vibe-typer-config] enforcing tracked settings (diff detected)"
tmp=$(mktemp "${CONFIG}.XXXXXX")
trap 'rm -f "$tmp"' EXIT
printf '%s\n' "$merged" > "$tmp"
mv -f "$tmp" "$CONFIG"
trap - EXIT
echo "[vibe-typer-config] done."
