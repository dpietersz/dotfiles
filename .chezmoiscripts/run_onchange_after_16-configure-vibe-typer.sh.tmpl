#!/bin/bash
# Settings hash: paste-modeMap=wayland-generic:type
# (Bump this comment when adding new settings to force re-apply.)

set -euo pipefail

# ------------------ Vibe Typer post-install config ------------------
# Vibe Typer writes its config to ~/.config/vibe-typer/config.json. Most of it
# is per-machine state (recentTargets, timestamps, language, etc.) that we
# DON'T want to track. We only enforce one critical setting:
#
#   user.textInsertion.paste.modeMap["wayland-generic"] = "type"
#
# Why: niri can't expose focused-window app-id via Wayland protocols that
# Vibe Typer understands (niri uses ext-foreign-toplevel-list-v1; Vibe Typer
# expects wlr-foreign-toplevel-management-v1). So every focused app is
# classified as the generic "wayland-generic" target. Vibe Typer's default
# "paste" mode sends Ctrl+V, which doesn't work in terminals (they need
# Ctrl+Shift+V). "type" mode types each character via uinput — universal.

{{- if or .remote .isMacOS }}
exit 0
{{- end }}

CONFIG="$HOME/.config/vibe-typer/config.json"
[ -f "$CONFIG" ] || { echo "[vibe-typer-config] config not yet created (run app once); skipping."; exit 0; }
command -v jq >/dev/null 2>&1 || { echo "[vibe-typer-config] jq not installed; skipping."; exit 0; }

current=$(jq -r '.user.textInsertion.paste.modeMap["wayland-generic"] // ""' "$CONFIG" 2>/dev/null || echo "")
if [ "$current" = "type" ]; then
    exit 0
fi

echo "[vibe-typer-config] setting paste.modeMap[wayland-generic] = type (was: ${current:-<unset>})"
tmp=$(mktemp "${CONFIG}.XXXXXX")
trap 'rm -f "$tmp"' EXIT
jq '.user.textInsertion.paste.modeMap["wayland-generic"] = "type"' "$CONFIG" > "$tmp"
mv -f "$tmp" "$CONFIG"
trap - EXIT
echo "[vibe-typer-config] done."
