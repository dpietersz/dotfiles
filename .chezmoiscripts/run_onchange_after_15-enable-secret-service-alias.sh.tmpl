#!/bin/bash
# unit hash: {{ include "dot_config/systemd/user/secret-service-default-alias.service" | sha256sum }}
# (Hash above forces this run_onchange script to re-fire whenever the unit file changes.)

set -euo pipefail

# Enable a tiny oneshot that sets the freedesktop SecretService default alias
# to the "login" collection on every login. niri sessions don't get this
# automatically (GNOME Shell normally does it), and Electron apps that use
# safeStorage with --password-store=gnome-libsecret fail without it.

{{- if or .remote .isMacOS }}
exit 0
{{- end }}

UNIT=secret-service-default-alias.service
SERVICE_FILE="$HOME/.config/systemd/user/$UNIT"
[ -f "$SERVICE_FILE" ] || { echo "[secret-alias] unit not found at $SERVICE_FILE"; exit 1; }

systemctl --user daemon-reload
systemctl --user enable "$UNIT" >/dev/null
# Run now (and on every apply) — idempotent: SetAlias with the same target is a no-op.
systemctl --user restart "$UNIT" || true

echo "[secret-alias] enabled and applied: $UNIT"
