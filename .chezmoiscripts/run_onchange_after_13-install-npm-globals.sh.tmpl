#!/bin/bash
{{- if .remote }}
exit 0
{{- end }}

# Global npm packages that aren't available via brew.
# - pi      → @earendil-works/pi-coding-agent  (terminal coding harness)
# - auggie  → @augmentcode/auggie               (Augment CLI)
#
# Installed via bun (preferred) or npm fallback. Bun globals live in ~/.bun/bin
# (already on PATH via dot_config/shell/10-path.sh.tmpl).
#
# Bump version-pin to force a reinstall pass.
# version-pin: 1

set -euo pipefail

PKGS=( "@earendil-works/pi-coding-agent" "@augmentcode/auggie" "mcp-hub" )

install_one() {
  local pkg="$1"
  echo "[npm-globals] Installing/updating ${pkg}@latest..."
  if command -v bun >/dev/null 2>&1; then
    bun install -g "${pkg}@latest"
  elif command -v npm >/dev/null 2>&1; then
    npm install --prefix "$HOME/.local/share/npm" --no-save --ignore-scripts "${pkg}@latest"
    # Keep PATH-visible bin symlink (matches existing dotfiles pattern)
    NPM_BIN_DIR="$HOME/.local/share/npm/bin"
    NPM_NODE_MODULES_BIN="$HOME/.local/share/npm/node_modules/.bin"
    if [[ -d "$NPM_NODE_MODULES_BIN" ]]; then
      mkdir -p "$NPM_BIN_DIR"
      ln -sf "$NPM_NODE_MODULES_BIN" "$NPM_BIN_DIR/.bin" 2>/dev/null || true
    fi
  else
    echo "[npm-globals] Neither bun nor npm available; skipping ${pkg}"
    return 0
  fi
}

for p in "${PKGS[@]}"; do
  install_one "$p"
done

echo "[npm-globals] ✓ Done"
