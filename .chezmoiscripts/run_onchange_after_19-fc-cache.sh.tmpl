#!/bin/bash
# run_onchange_after_19-fc-cache — refresh the user fontconfig cache when any
# font external has changed. fontconfig auto-scans ~/.fonts/ on its own
# schedule, but typst/pandoc queries within seconds of an apply would otherwise
# miss the just-extracted TTFs. Re-running on every apply would be wasteful;
# embedding the externals' content hashes makes this onchange-gated.
#
# Fingerprints (embedded so a font URL bump retriggers this script):
# inter:         {{ include ".chezmoiexternals/inter.toml" | sha256sum }}
# eb-garamond:   {{ include ".chezmoiexternals/eb-garamond.toml" | sha256sum }}
# ibm-plex-sans: {{ include ".chezmoiexternals/ibm-plex-sans.toml" | sha256sum }}
# meslo:         {{ include ".chezmoiexternals/meslo.toml.tmpl" | sha256sum }}
# departuremono: {{ include ".chezmoiexternals/departuremono.toml" | sha256sum }}
# noto-emoji:    {{ include ".chezmoiexternals/noto-color-emoji.toml" | sha256sum }}
# emoji-conf:    {{ include "dot_config/fontconfig/conf.d/75-emoji-color.conf" | sha256sum }}
# heal-script:   {{ include "dot_local/bin/scripts/executable_fontconfig-heal.sh" | sha256sum }}
set -euo pipefail

# Delegate to the shared verify-and-heal script rather than a blind `fc-cache -f`.
# A blind rebuild is what caused the durable failure: on this ostree/composefs
# image fc-cache can write a valid-but-EMPTY cache for /usr/share/fonts (epoch
# checksum validates forever), making Noto Serif/Liberation invisible so the
# ~360 Nerd Fonts win generic serif/sans and Chromium/Electron render monospace
# digits + wrong serif + tofu. The heal script detects that state (canary font
# missing / serif resolving to a Nerd Font) and rebuilds with an erase-and-retry
# loop until real fonts are visible. It pins /usr/bin/fc-cache over Homebrew's
# 2.18, and no-ops on macOS. The same script runs at login via
# refresh-fontconfig-cache.service.
HEAL="$HOME/.local/bin/scripts/fontconfig-heal.sh"
if [ -x "$HEAL" ]; then
    "$HEAL" || true
    echo "→ fontconfig cache verified/healed (font set changed)"
else
    # Script not deployed yet (first apply ordering) — fall back to a plain
    # rebuild with the system binary so this apply isn't a no-op.
    FC_CACHE=/usr/bin/fc-cache
    [ -x "$FC_CACHE" ] || FC_CACHE=$(command -v fc-cache || true)
    [ -n "$FC_CACHE" ] && "$FC_CACHE" -f >/dev/null 2>&1 || true
    echo "→ fontconfig cache refreshed (heal script not yet present)"
fi
