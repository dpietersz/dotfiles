#!/bin/bash
set -euo pipefail

{{- if .isBluefinUdx }}
# pass is baked into the bluefin-udx image; nothing to do here.
# Falls through to the legacy install logic on vanilla Bluefin / Fedora / macOS
# so this script stays useful as a fallback during migration.
exit 0
{{- end }}

{{ if not .remote -}}

echo "🔑 Installing pass (password-store CLI)"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

if command -v pass >/dev/null 2>&1; then
    echo "✅ pass already installed"
    exit 0
fi

echo "📦 Installing pass..."
{{- if eq .chezmoi.os "darwin" }}
if command -v brew >/dev/null; then
    brew install pass
else
    echo "❌ Homebrew not installed. Cannot install pass."
    exit 1
fi
{{- else if .isBluefin }}
echo "Installing pass via rpm-ostree..."
sudo rpm-ostree install -y pass
echo ""
echo "⚠️  REBOOT REQUIRED to complete pass installation"
echo "   After reboot, re-run: chezmoi apply"
echo ""
# Signal to setup.sh / interactive user that a reboot is needed.
# We exit non-zero so chezmoi does NOT mark this run_once as complete,
# guaranteeing this script re-runs after reboot until pass is on PATH.
exit 1
{{- else if .isFedora }}
if command -v dnf >/dev/null; then
    sudo dnf install -y pass
fi
{{- else }}
echo "❌ No installation instructions for pass on your distribution."
exit 1
{{- end }}

echo "✅ pass installed"

{{ end -}}
