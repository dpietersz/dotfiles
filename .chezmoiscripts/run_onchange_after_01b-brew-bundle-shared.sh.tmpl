#!/bin/bash
{{- if .remote }}
# Skip on remote environments
exit 0
{{- end }}

# Shared Brewfile install — runs on every machine (macOS + Linux/Bluefin).
# Hash trigger: re-runs when the Brewfile content changes.
# Brewfile hash: {{ include "dot_config/brewfiles/Brewfile.tmpl" | sha256sum }}

set -euo pipefail

# Source brew shellenv if brew isn't on PATH yet (Linux: linuxbrew installs
# to /home/linuxbrew/.linuxbrew/bin/brew but chezmoi's subshell doesn't
# inherit the user's shell rc). Idempotent — no-op if already on PATH.
if ! command -v brew >/dev/null 2>&1; then
  for cand in /home/linuxbrew/.linuxbrew/bin/brew /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$cand" ]]; then
      eval "$("$cand" shellenv bash)"
      break
    fi
  done
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "[brew-shared] brew not found, skipping (01-install-homebrew.sh runs first)"
  exit 0
fi

BREWFILE="{{ .chezmoi.homeDir }}/.config/brewfiles/Brewfile"

if [[ ! -f "$BREWFILE" ]]; then
  echo "[brew-shared] $BREWFILE not found (chezmoi has not rendered it yet?)"
  exit 1
fi

# Homebrew 6.0+ defaults HOMEBREW_REQUIRE_TAP_TRUST on, so non-core taps are
# skipped (and their formulae never install) unless explicitly trusted. Trust
# every tap THIS Brewfile declares — parsed from the file so it never drifts
# out of sync. Errors suppressed: no-op on pre-6.0 brew (no `trust` subcommand).
while IFS= read -r t; do
  [[ -n "$t" ]] && brew trust --tap "$t" >/dev/null 2>&1 || true
done < <(awk -F'"' '/^tap "/{print $2}' "$BREWFILE")

echo "[brew-shared] Installing/updating shared Brewfile..."
brew bundle install --file="$BREWFILE"

echo "[brew-shared] ✓ Done"
