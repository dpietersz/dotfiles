#!/bin/bash
{{- if or .remote .isMacOS .isServer (not .hasFingerprintReader) }}
# Only relevant on fingerprint laptops that log in via GDM. Fingerprint GDM
# login can't decrypt a password-protected gnome-keyring (a fingerprint is not
# the symmetric key), so the login keyring is set to an EMPTY password (one-time,
# via seahorse) and auto-unlocked by gnome-keyring-daemon. This script keeps it
# that way.
exit 0
{{- end }}

{{- if not (or .isBluefin .isFedora) }}
exit 0
{{- end }}

# ── Passwordless login keyring: stop PAM re-encrypting it ──────────────────────
# Problem this solves (the reason emptying the keyring "only worked a short
# while" before): gnome-keyring keeps the `login` keyring's password in sync with
# your account password via pam_gnome_keyring. After you empty the keyring, any
# event that hands pam_gnome_keyring your account password (a password GDM login,
# a `passwd` change, keyring recreation) re-encrypts it — and fingerprint logins
# then prompt again because a fingerprint can't decrypt it.
#
# Fix: remove pam_gnome_keyring from /etc/pam.d/gdm-password. The gnome-keyring
# secrets daemon (started by the systemd user manager) auto-unlocks an
# EMPTY-password login keyring on its own, with no PAM involvement — so secrets
# still work, but nothing ever re-encrypts the keyring behind your back.
#
# Safety: all three pam_gnome_keyring lines are `optional`, so commenting them
# out CANNOT change whether login auth succeeds — it only removes the keyring
# sync/auto-start side effect. We comment (never delete) and keep a .bak.
#
# Durability: the gdm-password hash below is rendered into this script, so when a
# gdm package update rewrites /etc/pam.d/gdm-password and restores the lines,
# this run_onchange re-fires and strips them again.
# gdm-password sha256: {{ output "bash" "-c" "sha256sum /etc/pam.d/gdm-password 2>/dev/null | cut -d' ' -f1 || echo none" | trim }}

set -euo pipefail

PAMFILE=/etc/pam.d/gdm-password

if [[ ! -f "$PAMFILE" ]]; then
    echo "[keyring-pam] $PAMFILE not found; skipping."
    exit 0
fi

# Already stripped? (no uncommented pam_gnome_keyring line remains)
if ! grep -qE '^[[:space:]]*[^#].*pam_gnome_keyring\.so' "$PAMFILE"; then
    echo "[keyring-pam] gdm-password already free of active pam_gnome_keyring lines."
    exit 0
fi

echo "[keyring-pam] commenting out pam_gnome_keyring in $PAMFILE (keeps login keyring passwordless)"
sudo cp -a "$PAMFILE" "${PAMFILE}.bak.$(date +%Y%m%d-%H%M%S)"

# Comment any active line that loads pam_gnome_keyring.so. Leading '-' (as in
# '-password') is preserved inside the comment for traceability.
sudo sed -i -E 's@^([[:space:]]*-?(auth|password|session)[[:space:]].*pam_gnome_keyring\.so.*)$@# [keyring-pam disabled] \1@' "$PAMFILE"

# Sanity: the core auth path (password-auth substack + selinux permit) must
# still be intact, else GDM login could break. Abort-restore if it looks wrong.
if ! grep -qE 'substack[[:space:]]+password-auth' "$PAMFILE"; then
    echo "[keyring-pam] SANITY FAILED — password-auth substack missing; restoring backup."
    LATEST_BAK=$(ls -t "${PAMFILE}".bak.* 2>/dev/null | head -1)
    [[ -n "$LATEST_BAK" ]] && sudo cp -a "$LATEST_BAK" "$PAMFILE"
    exit 1
fi

echo "[keyring-pam] ✓ done. Active pam_gnome_keyring lines remaining: $(grep -cE '^[[:space:]]*[^#].*pam_gnome_keyring\.so' "$PAMFILE")"
echo "[keyring-pam] NOTE: the login keyring must be set to an EMPTY password once (seahorse → Login → Change Password → blank)."
