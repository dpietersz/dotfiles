#!/bin/bash
# Enable the per-user ssh-agent service on Linux machines that don't
# already have one (gnome-keyring, KDE wallet, etc.). Idempotent.
{{- if not .remote }}
{{- if eq .chezmoi.os "linux" }}
set -euo pipefail

# Skip if an existing agent provider already owns the socket.
# gnome-keyring sets SSH_AUTH_SOCK to .../keyring/ssh; KDE wallet uses
# kwalletd. In those cases, don't fight them.
case "${SSH_AUTH_SOCK:-}" in
  */keyring/ssh|*/gnome-keyring/*|*/kwalletd/*)
    echo "ℹ  Existing ssh-agent provider in use (${SSH_AUTH_SOCK}) — skipping systemd unit"
    exit 0
    ;;
esac

# Need a user systemd manager. On servers without a graphical session,
# linger may not be enabled — that's fine, the unit only needs to run
# inside an active login session. Bail cleanly if neither is available.
if ! systemctl --user is-system-running >/dev/null 2>&1; then
  if [ -z "${XDG_RUNTIME_DIR:-}" ] || [ ! -d "${XDG_RUNTIME_DIR}/systemd" ]; then
    echo "⚠  No user systemd manager in this session — skipping ssh-agent enable."
    echo "   Re-run chezmoi apply from a normal login shell, or run:"
    echo "     loginctl enable-linger \$USER"
    echo "   to keep the user manager alive across logins."
    exit 0
  fi
fi

systemctl --user daemon-reload
systemctl --user enable --now ssh-agent.service

echo "✅ systemd-user ssh-agent.service enabled — socket at ${XDG_RUNTIME_DIR}/ssh-agent.socket"
{{- end }}
{{- end }}
