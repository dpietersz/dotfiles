#!/bin/bash
set -euo pipefail

# ------------------ Install / update Vibe Typer (AppImage) ------------------
# Vibe Typer ships only as a Linux AppImage. We track the upstream stable
# channel via cdn.vibetyper.com/releases/latest.json and re-download only when
# the version changes. AppImage lands in ~/Applications/, with a desktop entry
# in ~/.local/share/applications/ so it shows up in the launcher.
#
# Refs:
#   manifest: https://cdn.vibetyper.com/releases/latest.json
#   binary:   https://cdn.vibetyper.com/releases/linux/VibeTyper.AppImage

{{- if or .remote .isMacOS }}
exit 0
{{- end }}

MANIFEST_URL="https://cdn.vibetyper.com/releases/latest.json"
APPIMAGE_URL="https://cdn.vibetyper.com/releases/linux/VibeTyper.AppImage"
APP_DIR="$HOME/Applications"
APP_PATH="$APP_DIR/VibeTyper.AppImage"
STATE_DIR="$HOME/.local/state/vibe-typer"
VERSION_FILE="$STATE_DIR/version"
DESKTOP_FILE="$HOME/.local/share/applications/vibe-typer.desktop"

mkdir -p "$APP_DIR" "$STATE_DIR" "$(dirname "$DESKTOP_FILE")"

# Fetch upstream version (small JSON, ~100 bytes).
remote_version=$(curl -fsSL --max-time 10 "$MANIFEST_URL" 2>/dev/null \
    | python3 -c 'import sys,json; print(json.load(sys.stdin)["version"])' 2>/dev/null \
    || true)

if [ -z "$remote_version" ]; then
    echo "[vibe-typer] Could not reach $MANIFEST_URL; skipping (will retry on next apply)."
    exit 0
fi

local_version=$(cat "$VERSION_FILE" 2>/dev/null || echo "")

if [ "$local_version" != "$remote_version" ] || [ ! -x "$APP_PATH" ]; then
    echo "[vibe-typer] Installing $remote_version (was: ${local_version:-<none>})..."
    tmp=$(mktemp "$APP_DIR/.VibeTyper.AppImage.XXXXXX")
    trap 'rm -f "$tmp"' EXIT

    if ! curl -fSL --progress-bar --max-time 600 -o "$tmp" "$APPIMAGE_URL"; then
        echo "[vibe-typer] Download failed; keeping existing version (if any)."
        exit 1
    fi

    chmod +x "$tmp"
    mv -f "$tmp" "$APP_PATH"
    trap - EXIT
    echo "$remote_version" > "$VERSION_FILE"

    # Ensure libfuse2 / fuse-libs is present on Fedora atomic (AppImage runtime).
    if ! ldconfig -p 2>/dev/null | grep -q 'libfuse\.so\.2'; then
        echo "[vibe-typer] libfuse.so.2 not found — layering fuse-libs (may need reboot)..."
        sudo rpm-ostree install --apply-live --allow-inactive -y fuse-libs || \
            echo "[vibe-typer] fuse-libs layering deferred until next boot."
    fi
else
    echo "[vibe-typer] AppImage v$remote_version already current."
fi

# Desktop entry — always regenerated, so Exec-line changes (e.g. new flags) propagate.
cat > "$DESKTOP_FILE" <<EOF
[Desktop Entry]
Type=Application
Name=Vibe Typer
GenericName=Voice Dictation
Comment=AI voice typing — Vibe Typer
# --password-store=gnome-libsecret: forces Electron to use gnome-libsecret backend
# for safeStorage. Without it, Electron's auto-detect falls back to "basic"
# (plaintext) on non-GNOME/KDE sessions like niri, and the app refuses to sign in
# because it considers the keyring inaccessible.
Exec=$APP_PATH --password-store=gnome-libsecret
Icon=vibe-typer
StartupWMClass=VibeTyper
Categories=Utility;AudioVideo;Office;
Terminal=false
EOF
update-desktop-database "$(dirname "$DESKTOP_FILE")" 2>/dev/null || true

# ------------------ Icon extraction ------------------
# The AppImage bundles its icon set under squashfs-root/usr/share/icons/hicolor/.
# .desktop references Icon=vibe-typer but the AppImage doesn't install icons
# system-wide — without this extraction the launcher shows a blank fallback.
# Re-extract on every version bump so refreshed icons land.
ICON_BASE="$HOME/.local/share/icons/hicolor"
ICON_MARKER="$STATE_DIR/icons-${remote_version}"
if [ ! -f "$ICON_MARKER" ] || [ ! -f "$ICON_BASE/512x512/apps/vibe-typer.png" ]; then
    echo "[vibe-typer] Extracting icons from AppImage..."
    extract_dir=$(mktemp -d -t vibe-typer-icons.XXXXXX)
    trap 'rm -rf "$extract_dir"' RETURN  # cleanup whether we return or exit
    (
        cd "$extract_dir"
        "$APP_PATH" --appimage-extract 'usr/share/icons/hicolor/*' >/dev/null 2>&1 || true
    )
    copied=0
    for src in "$extract_dir"/squashfs-root/usr/share/icons/hicolor/*/apps/vibe-typer.png; do
        [ -f "$src" ] || continue
        rel="${src#$extract_dir/squashfs-root/usr/share/icons/hicolor/}"
        dest="$ICON_BASE/$rel"
        mkdir -p "$(dirname "$dest")"
        cp "$src" "$dest"
        copied=$((copied + 1))
    done
    rm -rf "$extract_dir"
    trap - RETURN
    if [ "$copied" -gt 0 ]; then
        echo "[vibe-typer] Installed $copied icon size(s) under $ICON_BASE"
        touch "$ICON_MARKER"
        command -v gtk-update-icon-cache >/dev/null && \
            gtk-update-icon-cache -t -q "$ICON_BASE" 2>/dev/null || true
    else
        echo "[vibe-typer] WARN: could not extract icons from AppImage"
    fi
fi

echo "[vibe-typer] Installed: $APP_PATH ($remote_version)"
echo "[vibe-typer] Launcher entry: $DESKTOP_FILE"
echo "[vibe-typer] First run: launch from your app launcher, configure the in-app hotkey."
