#!/bin/bash
set -euo pipefail

{{ if not .remote -}}

echo "🔑 Cloning password-store"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━"

if [ -d "$HOME/.password-store/.git" ]; then
    echo "✅ password-store already cloned. Pulling latest changes..."
    cd "$HOME/.password-store"
    git pull || echo "⚠️  git pull failed (continuing)"
    exit 0
fi

if ! command -v pass >/dev/null 2>&1; then
    echo "❌ pass is not installed yet. Did the reboot after rpm-ostree complete?"
    exit 1
fi

if [ ! -f "$HOME/.ssh/id_ed25519" ]; then
    echo "❌ SSH key missing — decrypt-keys must run before this script."
    exit 1
fi

echo "📥 Cloning password-store from GitLab..."
if ! git clone git@gitlab.com:pietersz-personal-tools/password-store.git "$HOME/.password-store"; then
    echo "❌ Failed to clone password-store. Check your SSH key and GitLab access."
    exit 1
fi

echo "✅ password-store cloned"

EXPECTED_GPG_ID="{{ .gpgKeyId }}"
REPO_GPG_ID=$(tr -d '[:space:]' < "$HOME/.password-store/.gpg-id")

if [ "$REPO_GPG_ID" != "$EXPECTED_GPG_ID" ]; then
    echo "⚠️  Warning: .gpg-id in repo ($REPO_GPG_ID) doesn't match expected ($EXPECTED_GPG_ID)"
fi

echo ""
echo "✅ password-store setup complete"
echo ""

{{ end -}}
