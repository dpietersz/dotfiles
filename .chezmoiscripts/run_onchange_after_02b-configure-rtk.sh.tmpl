#!/bin/bash
{{- if .remote }}
# Skip on remote environments — rtk is a dev-workstation token-saver wired into
# the Claude Code / pi agent harnesses, which aren't configured on remotes.
exit 0
{{- end }}

# Configure rtk (https://github.com/rtk-ai/rtk) for the locally-installed AI
# coding agents. rtk is a CLI proxy that filters/compresses command output to
# cut LLM token use 60-90%. The binary is installed via the shared Brewfile
# (`brew "rtk"`); this script wires it into the agents idempotently.
#
# Integrations (both via rtk's own idempotent installer — single source of
# truth, always matches the installed binary):
#   - Claude Code: PreToolUse Bash hook in ~/.claude/settings.json. We use
#     --hook-only so rtk does NOT touch ~/.claude/CLAUDE.md (PAI-managed). The
#     hook MERGES alongside existing PAI hooks (SecurityPipeline, etc.) and is
#     re-applied idempotently. settings.json is not chezmoi-managed.
#   - pi: a thin TypeScript extension at ~/.pi/agent/extensions/rtk.ts that
#     delegates to `rtk rewrite` on each tool_call. pi auto-loads it; chezmoi
#     does not track it, so there is no drift against dot_pi/agent/extensions/.
#
# Hash trigger: the rtk version comment below re-renders on upgrade, forcing
# this run_onchange to re-fire so the agent artifacts track the new binary.
# rtk version: {{ output "bash" "-c" "command -v rtk >/dev/null 2>&1 && rtk --version 2>/dev/null || echo none" | trim }}

set -euo pipefail

# Source brew shellenv if rtk/brew isn't on PATH yet (same shim as the brew
# bundle scripts — chezmoi's subshell doesn't inherit the user's shell rc).
if ! command -v rtk >/dev/null 2>&1; then
  for cand in /home/linuxbrew/.linuxbrew/bin/brew /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [[ -x "$cand" ]]; then
      eval "$("$cand" shellenv bash)"
      break
    fi
  done
fi

if ! command -v rtk >/dev/null 2>&1; then
  echo "[rtk] rtk not found on PATH — skipping (01b-brew-bundle-shared installs it first)."
  exit 0
fi

echo "[rtk] $(rtk --version) — configuring agent integrations"

# Claude Code — hook only (no CLAUDE.md/RTK.md mutation; merges into existing
# PAI hook chain). Skip if ~/.claude doesn't exist (Claude not installed here).
if [[ -d "$HOME/.claude" ]]; then
  echo "[rtk] Claude Code: installing PreToolUse Bash hook (hook-only, auto-patch)"
  rtk init -g --hook-only --auto-patch </dev/null
else
  echo "[rtk] Claude Code: ~/.claude absent — skipping"
fi

# pi coding agent — auto-loaded TypeScript extension.
if [[ -d "$HOME/.pi/agent" ]]; then
  echo "[rtk] pi: installing extension at ~/.pi/agent/extensions/rtk.ts"
  rtk init -g --agent pi </dev/null
else
  echo "[rtk] pi: ~/.pi/agent absent — skipping"
fi

echo "[rtk] ✓ Done. Restart Claude Code / pi to load the rewrite hooks."
